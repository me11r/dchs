{% extends "layout/html" %}
{% block content %}
    <div class="section container">
    <h4 class="title">Активные путевые листы</h4>
    <table class="table is-striped is-narrow is-fullwidth">
        <thead>
        <tr>
            <th>Номер листа</th>
            <th>Подразделение</th>
            <th>Адрес возгорания</th>
            <th>Дата и время</th>
            <th>&nbsp;</th>
            <th>&nbsp;</th>
        </tr>
        </thead>
        <tbody>
        {% for trip in trips %}
            <tr>
                <td>{{ trip.id }}</td>
                <td>{{ trip.department.name|default('-') }}</td>
                <td>{{ trip.location|default('-') }}</td>
                <td>{{ trip.created_at|date('d.m.Y H:i') }}</td>
                <td class="has-text-right"><a href="{{ url('/roadtrip-103/' ~ trip.id) }}" class="button is-outlined is-primary"><i class="far fa-address-card"></i>&nbsp;Путевой
                        лист</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td class="has-text-centered"><h4 class="subtitle">Нет открытых путевых листов</h4></td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% include "_templates/pagination" with {'items': trips, 'per_page': per_page} %}
    </div>
{% endblock content %}
