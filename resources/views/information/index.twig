{% extends "layout/html" %}
{% block content %}
    <div class="">
        <h4 class="title"
            style="padding: 3px 15px">Информация
        </h4>
    </div>
    <div class="columns is-gapless">
        <div style="width: 100%; border-bottom: 1px solid #dbdbdb;">
        </div>
        <div class="column is-narrow">
            <div style="border-bottom: 1px solid #dbdbdb">
                {#<a href="{{ route('information.create') }}" class="button is-success is-outlined"#}
                   {#style="margin: 2px 10px 2px">#}
                    {#<i class="fas fa-plus"></i>&nbsp;Добавить#}
                {#</a>#}
            </div>
        </div>
    </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>№</th>
                <th>Наименование организации</th>
                {#<th class="has-text-right">Дата и время</th>#}
                <th>&nbsp;</th>
            </tr>
            </thead>
            {% for item in items %}
                <tr>
                    <td class="has-text-right">{{ loop.index }}</td>
                    <td>
                        <a href="{{ item.name == 'ГУ Казселезащита' ? route('mudflowProtection.index') :
                        (item.name == 'РГП Казгидромет' ? route('weather.index') : route('quakes.index'))}}">
                            {{ item.name }}
                        </a>
                    </td>
                    <td class="has-text-right"></td>
                    <td class="has-text-right">
                        {#<a href="{{ route('information.edit', item.id) }}"#}
                           {#class="button is-small is-outlined is-primary">#}
                            {#<i class="fas fa-pencil-alt"></i>&nbsp;#}
                            {#Редактировать#}
                        {#</a>#}
                    </td>
                </tr>
            {% endfor %}
        </table>
    </div>
{% endblock content %}