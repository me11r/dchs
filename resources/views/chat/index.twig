{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="level">
            <div class="level-left">
                <h4 class="title"
                    >События
                </h4>
            </div>
            <div class="level-right">
                <div class="field is-grouped">
                    <a href="{{ route('nicknames.index') }}" class="button is-info is-main"
                       style="margin: 2px 10px 2px"><i class="fas fa-comments"></i>&nbsp;
                        Позывные
                    </a>
                    <a href="{{ route('chats.create') }}" class="button is-basic is-main"
                       style="margin: 2px 10px 2px">
                        <i class="fas fa-plus"></i>&nbsp;Новое событие
                    </a>
                </div>
            </div>
        </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>№</th>
                <th>Событие</th>
                <th>&nbsp;</th>
            </tr>
            </thead>
            {% for item in items %}
                <tr>
                    <td class="has-text-right">{{ loop.index }}</td>
                    <td>{{ item.name }}</td>
                    <td class="has-text-right">
                        <form onsubmit="return confirm('Вы действительно хотите удалить эту запись?');"
                              method="POST"
                              action="{{ route('chats.destroy', item.id) }}">
                            {{ csrf_field() }}
                            <input type="hidden" name="_method" value="DELETE">

                            <a href="{{ route('messages.index', {'chatId': item.id}) }}"
                               class="button is-small is-primary">
                                <i class="fas fa-comment-alt"></i>&nbsp;
                                Сообщения
                            </a>

                            <a href="{{ route('chats.edit', item.id) }}"
                               class="button is-basic is-small">
                                <i class="fas fa-pencil-alt"></i>&nbsp;
                                Редактировать
                            </a>

                            <button title="Удалить"
                                    class="button is-small is-danger">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </table>
    </div>
    </div>
{% endblock content %}
