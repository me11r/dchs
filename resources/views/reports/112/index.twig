{% extends "layout/html" %}
{% block content %}
    <div class="container section" id="vue">
        <h1 class="title">{{ t('/reports/analytics101.title') }}</h1>{#Аналитика ДЧС#}
        <b-tabs position="is-centered" class="block" id="other-rides-block">

            {% if user.hasRight('CAN_ACCESS_REPORT_112_EMERGENCY_PERIOD') %}
                <b-tab-item label="{{ t('/reports/analytics101.tabs.report_112_period.tab_title') }}">{#Отчет 112 за период#}
                    <report112-emergency
                            :reasons="{{ incident_types }}"
                            :emergency-names="{{ emergency_names }}"
                            :city-areas="{{ city_areas }}"
                    ></report112-emergency>
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('CAN_ACCESS_REPORT_BRANCHES') %}
                <b-tab-item label="{{ t('/reports/analytics101.tabs.branches_fall.tab_title') }}">{#Подтопления / падения веток#}
                    <report112-branches
                            :incident-types="{{ branches }}"
                            :emergency-names="{{ emergency_names }}"
                            :reasons-flooding="{{ reasons_flooding }}"
                            :reasons-branches="{{ reasons_branches }}"
                            :city-areas="{{ city_areas }}"
                    />
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('CAN_ACCESS_REPORT_112_EMERGENCY_REPORT') %}
                <b-tab-item label="{{ t('/reports/analytics101.tabs.emergency_situations.tab_title') }}">{#Чрезвычайные ситуации#}
                    <report-emergency-type-period
                            :incident-types="{{ incidentTypes }}"
                            :trip-results="{{ tripResults }}"
                            :emergency-names="{{ emergency_names }}"
                            :city-areas="{{ city_areas }}"
                    >
                    </report-emergency-type-period>
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('CAN_ACCESS_REPORT_BRANCHES') %}
                {#Отчет 112 По происшествиям#}
                <b-tab-item label="{{ t('/reports/analytics101.tabs.report112_emergency.tab_title') }}">
                    <report112-branches
                            :incident-types="{{ incident_types }}"
                            :emergency-names="{{ emergency_names }}"
                            :city-areas="{{ city_areas }}"
                    />
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('QUAKES_REPORT_SHOW') %}
                {#Случаи землетрясения#}
                <b-tab-item label="{{ t('/reports/analytics101.tabs.quakes.tab_title') }}">
                    <report-quakes
                    ></report-quakes>
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('AVALANCHES_REPORT_SHOW') %}
                {#Сход лавин#}
                <b-tab-item label="{{ t('/reports/analytics101.tabs.avalanches.tab_title') }}">
                    <report-avalanches
                        :avalanche-types="{{ avalanche_types }}"
                    ></report-avalanches>
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('ELEVATOR_REPORT_SHOW') %}
                {#Информация происшествия на лифтах#}
                <b-tab-item label="{{ t('/reports/analytics101.tabs.elevators.tab_title') }}">
                    <report-elevators
                        :elevator-emergency-types="{{ elevator_emergency_types }}"
                        :city-areas="{{ city_areas }}"
                    ></report-elevators>
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('DISEASE_REPORT_SHOW') %}
                <b-tab-item label="Инфекционные заболевания">
                    <report-disease
                        :disease-types="{{ disease_types }}"
                    ></report-disease>
                </b-tab-item>
            {% endif %}

            {% if user.hasRight('STAFF_MANAGERS_ODS_REPORT_SHOW') %}
                <b-tab-item label="Отчет по личному составу ДЧС">
                    <report-staff-managers-ods
                        :staff="{{ dchs_staff }}"
                        :og="{{ og }}"
                    ></report-staff-managers-ods>
                </b-tab-item>
            {% endif %}

        </b-tabs>

    </div>
{% endblock %}