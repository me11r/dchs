{% extends "layout/html" %}

{% block content %}
    <div class="container section" id="vue">
        <div class="panel">
            <div class="box" style="margin-top: 20px">
                <h4 class="title">{{ title }}</h4>
                <form action="{{ record.id is defined ? route('reports-call-infos.update', {'id':record.id}) : route('reports-call-infos.store')}}" method="post">
                    {% if record.id is defined %}
                        {{  method_field('PUT') }}
                    {% endif %}
                    {{ csrf_field() }}

                    <call-info-create-edit
                        :input-record="{{ record }}"
                    >
                    </call-info-create-edit>

                    <div class="buttons has-text-right is-grouped is-right" style="">
                        <button type="submit" class="button is-success"><i class="fas fa-check"></i>&nbsp;{{ t('save') }}</button>{#Сохранить#}
                        <a href="{{ url('/reports/call-infos/') }}" class="button is-light">{{ t('cancel') }}</a>{#Отменить#}
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock content %}
