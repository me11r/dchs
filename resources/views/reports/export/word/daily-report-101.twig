                Ликвидировано стволами: {{ item.liquidation_method ? item.liquidation_method.name : '' }}
                Дополнительная информация: {{ item.more_info }}
            </p>
        {% endfor %}
    {% endif %}

    {% if dischargesElectr.items | length > 0 %}
        <p style="margin: 0 auto;width: 50%"><b>{{ dischargesElectr.name }}:</b></p>
        {% for item in dischargesElectr.items %}
            <p>
                <b>{{ loop.index }}. {{ item.created_at | date('d.m.Y') }}г. {{ item.created_at | date('H') }}
                    час. {{ item.created_at | date('i') }} мин.
                    {{ item.city_area ? item.city_area.name : '' }}, {{ item.location }}:</b>
            </p>
            <p>
                (заявитель: {{ item.caller_name }}, тел: {{ item.caller_phone }}).
                ПЧ осуществляющая выезд:
                {% for department in item.departments %}
                    {{ department.title }} {{ not loop.index ? ',': '' }}
                {% endfor %}.
                Результат выезда - {{ item.trip_result ? item.trip_result.name : '' }}.
                Ликвидировано стволами: {{ item.liquidation_method ? item.liquidation_method.name : '' }}
                Дополнительная информация: {{ item.more_info }}
            </p>
        {% endfor %}
    {% endif %}

    <br/>
    <br/>
    {% for title, tripResult in tripResults %}
        <div style="padding-top: 50px; margin: 0 auto;width: 50%; ">{{ title }}:</div>
        {% for tripItem in tripResult %}
            <div>
                {{ loop.index }}. {{ tripItem.analytics|raw }}
            </div>
        {% endfor %}
        <br/>
    {% endfor %}

    <div><b>Проверка частей:</b></div>
    {% for title, check in fireDeptChecks %}
        <div>{{ loop.index }}.{{ check.fire_department.title }}: {{ check.time_begin }}
            - {{ check.time_end }} {{ check.responsible_person }} {{ check.note }}</div>
    {% endfor %}

</div>