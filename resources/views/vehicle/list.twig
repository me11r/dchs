{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="panel">
            <div class="level"">
                <div class="level-left">
                    <h4 class="title">{{ dictinfo.title }}</h4>
                </div>
                <div class="level-right has-text-right">
                    <a href="{{ url('/dictionaries/edit/' ~ dictinfo.id ~ '/') }}" class="button is-main is-basic"><i class="fas fa-plus"></i>&nbsp;Создать запись</a>
                </div>
            </div>
            <table class="table is-striped is-narrow is-hoverable">
                <thead>
                <tr>
                    <th>№</th>
                    {% for field in fields %}
                        <th>{{ field }}</th>
                    {% endfor %}
                    <th>&nbsp;</th>
                </tr>
                </thead>
                <tbody>
                {% for record in dictionary %}
                    <tr>
                        <td>{{ record.id }}</td>
                        {% for field in fields %}
                            <td class="max-width: 20%">{{ attribute(record, field) }}</td>
                        {% endfor %}
                        <td><a href="{{ url('dictionaries/edit/' ~ dictinfo.id ~ '/' ~ record.id) }}" class="button is-small is-basic"><i class="fas fa-edit"></i>&nbsp;Изменить</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td><h5 class="">Нет записей</h5></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock content %}
