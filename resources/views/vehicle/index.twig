{% extends "layout/html" %}
{% block content %}
    <div class="container">
        <div class="panel">
            <h4 style="" class="title">Автотехника</h4>
            <div class="level-right has-text-right">
                <a href="{{ route('vehicles.create') }}" class="button is-success"><i class="fas fa-plus"></i>&nbsp;Создать запись</a>
            </div>
            <table class="table is-narrow is-hoverable is-selectable">
                <thead>
                <tr>
                    <th>Модель</th>
                    <th>Номер</th>
                    <th>ПЧ</th>
                    <th>Тип</th>
                    <th></th>
                </tr>
                </thead>
                {% for item in items %}
                    <tr>
                        <td><i class="fas fa-list-ol"></i>&nbsp;{{ item.name }}</td>
                        <td>{{ item.number }}</td>
                        <td>{{ item.fireDepartment.name ?? '' }}</td>
                        <td>{{ item.vehicleType.name }}</td>
                        <td>
                            <a class="button is-outlined is-small" href="{{ route('vehicles.edit', {'id':item.id}) }}">
                                <i class="fas fa-edit"></i>&nbsp;Редактировать</a>

                            <form method="post" action="{{ route('vehicles.destroy', {'id':item.id}) }}">
                                {{ csrf_field() }}
                                {{  method_field('DELETE') }}
                                <button onclick="return confirm('Удалить запись?');" class="button is-outlined is-small">
                                    <i class="fas fa-crosshairs"></i>&nbsp;Удалить</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <li><h3 class="is-danger">Нет автотехники</h3></li>
                {% endfor %}
            </table>
        </div>
    </div>
{% endblock content %}