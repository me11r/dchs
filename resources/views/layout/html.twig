<!doctype html>
<html lang="{{ config('app.locale') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>{{ config('app.name') }}</title>
    <script>
      window.csrf_token = '{{ csrf_token() }}';
      window.language = '{{ language }}';
    </script>
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-touch-icon.png">
    <meta name="apple-mobile-web-app-status-bar-style" content="#5bbad5">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5">
    <link rel="prefetch" href="{{ mix('assets/app.js') }}">
    <link rel="preload" href="{{ mix('assets/app.js') }}" as="script">
    <meta name="msapplication-TileColor" content="#b91d47">
    <meta name="theme-color" content="#ffffff">
    <meta name="csrf-token" content="{{ csrf_token() }}">

    <link rel="manifest" href="{{ asset('/manifest.json') }}">

    <script src="https://www.gstatic.com/firebasejs/5.5.5/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/5.5.5/firebase-messaging.js"></script>
    <link rel="stylesheet" href="{{ mix('/assets/app.css') }}">
    {% if _global_ajax_timers is defined %}
        <script>
            window._global_ajax_timers = {{ _global_ajax_timers|raw }}
        </script>
    {% else %}
        <script>
          window._global_ajax_timers = {% verbatim %}{'check_service_plans':true, 'check_roadtrips': true, 'popup_notifications': true}{% endverbatim %}
        </script>
    {% endif %}
</head>
<body>
<nav id="navbar" class="app-navbar"></nav>
{% if _message is defined %}
    <div id="notification" class="animated shake notification is-{{ _message.type|default('info') }}">{{ _message.text|default('Unknown error') }}</div>
{% endif %}
<section class="page-body">
    <div id="popup_notification"></div>
    {% block content %}{% endblock content %}
</section>
<div id="roadtrip_notifier"></div>
<div id="service_plans_notifier"></div>
<div id="emergency_messenger"></div>
<script src="{{ mix('assets/app.js') }}"></script>
<script>
  window.addEventListener('load', () => {
    const notify = document.getElementById('notification');
    if (notify) {
      notify.addEventListener('transitionend', () => {
        notify.style.display = 'none';
      });
      notify.style.opacity = 0;
    }
  });
</script>
{% block scripts %}{% endblock scripts %}
<style>
    #notification {
        transition: opacity ease-out 10s;
    }
</style>
</body>
</html>
