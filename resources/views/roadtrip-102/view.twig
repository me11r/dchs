{% extends "layout/html" %}
{% block content %}
    <script src="https://api-maps.yandex.ru/2.1/?lang=ru-RU" type="text/javascript"></script>
    <script>
        window.addEventListener('load', () => {
            window.copiesToPrint = {{ record.roadtrips|length }},
            window.roadTripViewData = {
                fromString: 'Алматы {{ record.location }}',
                emergencyString: 'Алматы {{ record.department_id }}',
            };
            ymaps.ready(function () {
                window.ymaps = ymaps;
                window.initRoadTripViewMap();
            });
        });
    </script>
    <div class="section">
        <div class="level">
            <div class="level-left">
                <h4 class="title">Путевой лист {{ record.id }} от {{ record.created_at|date('d.m.Y H:i') }} для Городской клинической больницы №7</h4>
            </div>
            <div class="level-right printing-invisible">
                <a class="button is-outlined is-large print-button" id="open-print-button"><i class="fas fa-fw fa-print"></i>&nbsp;Печать</a>
            </div>
        </div>
        <table class="table is-narrow printing-full-width">
            <tr>
                <td class="has-text-right is-bold">Адрес</td>
                <td>{{ record.location|default('-') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Район</td>
                <td>{{ record.cityArea.name|default('-') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Происшествие</td>
                <td>{{ record.incident_type_id|default('-') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Предварительная информация</td>
                <td>{{ record.pre_information|default('-') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Состав высылаемых сил и средств</td>
                <td>
                    {#{% if not record.accept_time %}#}
                        {#{% for i in record.roadtrips %}#}
                            {#<p>{{ i.department_title }}</p>#}
                        {#{% endfor %}#}
                    {#{% else %}#}
                        <div id="vue">
                            {% for dep in record.roadtrips %}
                                {#{% if dep.out_time|default(null) is null and dep.accept_time %}#}
                                    <roadtrip102-dept-btn :record="{{ record }}" :dep="{{ dep }}"></roadtrip102-dept-btn>
                                {#{% endif %}#}
                            {% endfor %}
                        </div>
                    {#{% endif %}#}

                </td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">ФИО заявителя</td>
                <td>{{ record.caller_name|default('-') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Телефон заявителя</td>
                <td>{{ record.caller_phone|default('-') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Время получения сообщения о ЧС</td>
                <td>{{ record.created_at|date('d.m.Y H:i') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Дата(день,месяц,год)</td>
                <td>{{ record.created_at|date('d.m.Y') }}</td>
            </tr>
            <tr>
                <td class="has-text-right is-bold">Дополнительная информация</td>
                <td>{{ record.add_info|default('') }}</td>
            </tr>
        </table>

        <div id="road-trip-view-yandex-map-block"></div>
        <div id="autoprint" data-id="{{ record.id }}"></div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const printButton = document.getElementById('open-print-button');
            printButton.addEventListener('click', (e) => {
                window.print();
                e.preventDefault();
            });

        });
    </script>
{% endblock content %}
