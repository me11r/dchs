{% extends "layout/html" %}
{% block content %}
    <div class="panel">
        <div class="level">
            <div class="level-left">
                <h4 class="title" style="padding: 3px 15px">{{ t('/morainic-lakes-summaries.lakes_info_date', {date:date|date('d.m.Y')}) }}</h4>{#Сводная информация по мореным озерам на {{ date|date('d.m.Y') }}#}
            </div>
            <div class="level-right">
                <a href="/morainic-lakes-summaries/export/xls/{{ date }}" class="button is-success">{{ t('') }}</a>{#Сохранить в XLS#}
            </div>
        </div>
        <br>
        <table class="formation-record-table">
            <thead>
            <tr>
                <th>№</th>
                <th>{{ t('/morainic-lakes-summaries.name_altitude') }}</th>{#Наименование озера и абс.высота#}
                <th>{{ t('/morainic-lakes-summaries.initial_volume') }}</th>{#Первоначальный объём воды, (тыс.куб.м)#}
                <th>{{ t('/morainic-lakes-summaries.current_volume') }}</th>{#Текущий объём воды, (тыс.куб.м)#}
                <th>{{ t('/morainic-lakes-summaries.inflow_glacier') }}</th>{#Приток воды с ледника, (л/с)#}
                <th>{{ t('/morainic-lakes-summaries.drainage_via_evacuation_channel') }}</th>{#Отвод воды через эвак. канал#}
                <th>{{ t('/morainic-lakes-summaries.drainage_via_pump') }}</th>{#Отвод воды через насосы, (л/сек)#}
                <th>{{ t('/morainic-lakes-summaries.drainage_via_siphon') }}</th>{#Отвод воды через Сифоны, л/с)#}
                <th>{{ t('/morainic-lakes-summaries.water_dropped_day') }}</th>{#Всего сброшено воды,(тыс.куб.м) за сутки#}
                <th>{{ t('/morainic-lakes-summaries.water_dropped_total') }}</th>{#Всего сброшено воды,(тыс.куб.м) с начала работы#}
                <th>{{ t('/morainic-lakes-summaries.lowering_from_initial1') }} {{ date }}</th>{#Понижение от первоначального уровня, (м). {{ date }}#}
                {% if compare_with is defined and compare_with %}
                    <th>{{ t('/morainic-lakes-summaries.lowering_from_initial1') }} {{ comparedRecord.date ?? '' }}</th>{#Понижение от первоначального уровня, (м). #}
                {% endif %}
                <th>{{ t('/morainic-lakes-summaries.temperature_water') }}</th>{#t&deg; воды#}
                <th>{{ t('/morainic-lakes-summaries.temperature_air') }}</th>{#t&deg; воздуха#}
                <th>{{ t('/morainic-lakes-summaries.zero_isotherm') }}</th>{#Нулевая изотерма#}
                {#<th></th>#}
            </tr>
            </thead>
            {% for key, item in lakesSummary %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ item.lake.name ~ ' ' ~ item.lake.altitude }}</td>
                    <td>{{ item.initial_volume }}</td>
                    <td>{{ item.current_volume }}</td>
                    <td>{{ item.inflow_glacier }}</td>
                    <td>{{ item.drainage_via_evacuation_channel }}</td>
                    <td>{{ item.drainage_via_pump }}</td>
                    <td>{{ item.drainage_via_siphon }}</td>
                    <td>{{ item.water_dropped_day }}</td>
                    <td>{{ item.water_dropped_total }}</td>
                    <td>{{ item.lowering_from_initial1 }}</td>
                    {% if compare_with is defined and compare_with %}
                        <td>{{ comparedRecords.get()[key].lowering_from_initial1 ?? '' }}</td>
                    {% endif %}
                    {#<td>{{ item.lowering_from_initial2 }}</td>#}
                    <td>{{ item.temperature_water }}</td>
                    <td>{{ item.temperature_air }}</td>
                    <td>{{ item.zero_isotherm }}</td>
                </tr>
            {% endfor %}
            <tr>
                <td colspan="2" rowspan="2">{{ t('/morainic-lakes-summaries.total') }}:</td>{#Всего#}
                <td rowspan="2"><span class="has-text-weight-bold">{{ lakesSumRaw.sum('initial_volume') }}</span></td>
                <td rowspan="2"><span class="has-text-weight-bold">{{ lakesSumRaw.sum('current_volume') }}</span></td>
                <td rowspan="2"><span class="has-text-weight-bold">{{ lakesSumRaw.sum('inflow_glacier') }}</span></td>
                <td>{{ lakesSumRaw.sum('drainage_via_evacuation_channel') }}</td>
                <td>{{ lakesSumRaw.sum('drainage_via_pump') }}</td>
                <td>{{ lakesSumRaw.sum('drainage_via_siphon') }}</td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                {#<td></td>#}
            </tr>
            <tr>
                <td colspan="3">{{ lakesSumRaw.sum('drainage_via_evacuation_channel') + lakesSumRaw.sum('drainage_via_pump') + lakesSumRaw.sum('drainage_via_siphon') }}</td>
                <td>{{  lakesSumRaw.sum('water_dropped_day')  }}</td>
                <td>{{  lakesSumRaw.sum('water_dropped_total')  }}</td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
            <tr>
                <td>{{ t('/morainic-lakes-summaries.compare_with') }}{#Сравнение с#}
                    <form action="" method="get">
                        <div class="column">
                            <label for=""></label>
                            <select onchange="this.form.submit()" name="compare_with" id="">
                                <option value=""></option>
                                {% for record in otherRecords %}
                                    <option {{ compare_with is defined and compare_with == record.date ? 'selected' : '' }} value="{{ record.date }}">{{ record.date|date('d.m.Y') }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </form>
                </td>
                <td>
                </td>
                <td>
                    {% if compare_with is defined and comparedRecord %}
                        {{ comparedRecordsResult.initial_volume }}
                    {% endif %}
                </td>
                <td>
                    {% if compare_with is defined and compare_with %}
                        {{ comparedRecordsResult.current_volume }}
                    {% endif %}
                </td>
                <td>
                    {% if compare_with is defined and compare_with %}
                        {{ comparedRecordsResult.inflow_glacier }}
                    {% endif %}
                </td>
                <td colspan="3">
                    {% if compare_with is defined and compare_with %}
                        {{ comparedRecordsResult.drainage_total }}
                    {% endif %}
                </td>
                <td>
                    {% if compare_with is defined and compare_with %}
                        {{ comparedRecordsResult.water_dropped_day }}
                    {% endif %}
                </td>
                <td>
                    {% if compare_with is defined and compare_with %}
                        {{ comparedRecordsResult.water_dropped_total }}
                    {% endif %}
                </td>
                <td></td>
                <td></td>
                <td></td>
                {#<td></td>#}
                <td>{% if compare_with is defined and compare_with %}
                        {{ comparedRecordsResult.zero_isotherm }}
                    {% endif %}
                </td>
            </tr>

        </table>
        <form action="/morainic-lakes-reports/{{ date }}/update" method="post">
            {{ csrf_field() }}
            <div class="column">
                <label for="note">{{ t('note') }}</label>{#Примечание#}
                <textarea class="textarea" name="note">{{ report.note|default('') }}</textarea>
            </div>
            <div class="column">
                <button class="button is-primary">{{ t('save') }}</button>{#Сохранить#}
            </div>

        </form>
    </div>
{% endblock content %}