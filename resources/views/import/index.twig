    <div class="panel" id="vue">
        <section class="container">
            <form action="{{ custom_route('import.special_plans') }}" method="post" enctype='multipart/form-data'>
                {{ csrf_field() }}
                <div class="field">
                    <div class="file is-info has-name">
                        <label class="file-label">
                            <input class="file-input" type="file" name="file" required>
                            <span class="file-cta">
                                <span class="file-icon">
                                    <i class="fas fa-upload"></i>
                                </span>
                                <span class="file-label">
                                    Оперативные планы
                                </span>
                             </span>
                        </label>
                    </div>
                    <button style="margin-top: 20px" type="submit" class="button is-success">
                        <i class="fas fa-check"></i>&nbsp; Импортировать
                    </button>
                </div>
            </form>

