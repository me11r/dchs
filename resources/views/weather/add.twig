{% extends "layout/html" %}

{% block content %}
    <div class="container">
        <div class="panel">
            <div class="box" style="margin-top: 20px">
                <h4 class="title">Добавить</h4>
                <form action="{{ route('weather.store') }}" method="post" enctype="multipart/form-data">
                    {{ csrf_field() }}
                    <div class="field">
                        <label for="date">Дата</label>
                        <input type="date" class="input" name="date" id="date" value="{{ "" | date('now()') }}" required />
                    </div>
                    <div class="field">
                        <input type="file" name="file" required />
                    </div>
                    <div class="buttons has-text-right is-grouped is-right" style="">
                        <button type="submit" class="button is-success"><i class="fas fa-check"></i>&nbsp;Сохранить
                        </button>
                        <a href="{{ route('weather.index') }}" class="button is-light">Отменить</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock content %}