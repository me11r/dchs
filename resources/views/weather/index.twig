{% extends "layout/html" %}
{% block content %}
    <div class="">
        <h4 class="title"
            style="padding: 3px 15px">РГП Казгидромет
        </h4>
    </div>
    <div class="columns is-gapless">
        <div style="width: 100%; border-bottom: 1px solid #dbdbdb;">
        </div>
        <div class="column is-narrow">
            <div style="border-bottom: 1px solid #dbdbdb">
                <a href="{{ route('weather.create') }}" class="button is-success is-outlined"
                   style="margin: 2px 10px 2px">
                    <i class="fas fa-plus"></i>&nbsp;Добавить
                </a>
            </div>
        </div>
    </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>№</th>
                <th>Дата и время</th>
                <th>&nbsp;</th>
            </tr>
            </thead>
            {% for item in items %}
                <tr>
                    <td class="has-text-right">{{ loop.index }}</td>
                    <td>
                        {{ item.date | date('d.m.Y') }}
                    </td>
                    <td class="has-text-right">
                        <a href="{{ '/storage/weather/'~item.file }}" target="_blank">
                            Вложенный файл
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </table>
    </div>
{% endblock content %}