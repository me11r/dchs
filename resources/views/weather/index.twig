{% extends "layout/html" %}
{% block content %}
    <div class="section container">
        <div class="level">
    <div class="level-left">
        <h4 class="title"
            >РГП Казгидромет
        </h4>
    </div>
        <div class="level-right">
            <a href="{{ route('weather.create') }}" class="button is-main is-basic"
               style="">
                <i class="fas fa-plus"></i>&nbsp;Добавить
            </a>
        </div>
        </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>№</th>
                <th>Дата и время</th>
                <th>&nbsp;</th>
            </tr>
            </thead>
            {% for item in items %}
                <tr>
                    <td class="has-text-right">{{ loop.index }}</td>
                    <td>
                        {{ item.date | date('d.m.Y') }}
                    </td>
                    <td class="has-text-right">
                        <a href="/weather/{{ item.id }}/edit" class="button is-info is-small">
                            <i class="fas fa-file-upload"></i>&nbsp;
                            Редактировать
                        </a>
                        {% if user and user.hasRight('CAN_DELETE_INFO_WEATHER') %}
                            <form method="post" action="/weather/{{ item.id }}" style="display: inline">
                                {{ csrf_field() }}
                                {{ method_field('DELETE') }}
                                <button onclick="return confirm('Удалить?');"
                                        class="button is-small is-danger">
                                    <i class="fas fa-times"></i>&nbsp;
                                    Удалить
                                </button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </table>
    </div>
    </div>
{% endblock content %}
