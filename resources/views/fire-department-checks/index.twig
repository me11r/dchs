{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="panel">
            <div class="level">
                <div class="level-left">
                    <h4 style="" class="title">Проверка пожарных частей</h4>
                </div>
                <div class="level-right has-text-right">
                    <a href="{{ route('fire-department-checks.create') }}" class="button is-main is-basic"><i class="fas fa-plus"></i>&nbsp;Создать запись</a>
                </div>
            </div>
            <table class="table is-narrow is-striped is-hoverable is-selectable">
                <thead>
                <tr>
                    <th>Дата</th>
                    <th>&nbsp;</th>
                </tr>
                </thead>
                {% for item in items %}
                    <tr>
                        <td>{{ item.date }}</td>
                        <td>
                            <div class="field is-grouped">
                            <a class="button is-basic is-small" href="{{ route('fire-department-checks.edit-by-date', {'date':item.date}) }}">
                                <i class="fas fa-edit"></i>&nbsp;Смотреть</a>
                            </div>
                        </td>
                    </tr>

                {% else %}
                    <li><h3 class="is-danger">Нет данных</h3></li>
                {% endfor %}


            </table>

            {% include "_templates/pagination" with {'items': items, 'per_page': per_page} %}

        </div>
    </div>
{% endblock content %}
