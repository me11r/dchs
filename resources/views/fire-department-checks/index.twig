{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="panel">
            <div class="level">
                <div class="level-left">
                    <h4 style="" class="title">Проверка части</h4>
                </div>
                <div class="level-right has-text-right">
                    <a href="{{ route('fire-department-checks.create') }}" class="button is-main is-basic"><i class="fas fa-plus"></i>&nbsp;Создать запись</a>
                </div>
            </div>
            <table class="table is-narrow is-striped is-hoverable is-selectable">
                <thead>
                <tr>
                    <th>ПЧ</th>
                    <th>Ответственное лицо</th>
                    <th>Дата</th>
                    <th>&nbsp;</th>
                </tr>
                </thead>
                {% for item in items %}
                    <tr>
                        <td><i class="fas fa-list-ol"></i>&nbsp;{{ item.fire_department.title ?? '' }}</td>
                        <td>{{ item.responsible_person }}</td>
                        <td>{{ item.created_at.format('d.m.Y') }}</td>
                        <td>
                            <div class="field is-grouped">
                            <a class="button is-basic is-small" href="{{ route('fire-department-checks.edit', {'id':item.id}) }}">
                                <i class="fas fa-edit"></i>&nbsp;Редактировать</a>

                            <form method="post" action="{{ route('fire-department-checks.destroy', {'id':item.id}) }}">
                                {{ csrf_field() }}
                                {{  method_field('DELETE') }}
                                <button onclick="return confirm('Удалить запись?');" class="button is-danger is-small">
                                    <i class="fas fa-trash"></i>&nbsp;Удалить</button>
                            </form>
                            </div>
                        </td>
                    </tr>

                {% else %}
                    <li><h3 class="is-danger">Нет автотехники</h3></li>
                {% endfor %}


            </table>

            {% include "_templates/pagination" with {'items': items, 'per_page': per_page} %}

        </div>
    </div>
{% endblock content %}
