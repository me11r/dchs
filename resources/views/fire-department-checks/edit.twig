{% extends "layout/html" %}
{% block content %}
    <div class="container section" id="vue">
        <div class="panel">
            <div class="box" style="margin-top: 20px">
                <h4 class="title">Проверка части {{ record.created_at.format('d.m.Y')|default('') }}</h4>
                <form action="{{ record is defined ? route('fire-department-checks.update', {'id':record.id}) : route('fire-department-checks.store')}}" method="post">
                    {% if record is defined %}
                        {{  method_field('PUT') }}
                    {% endif %}
                    {{ csrf_field() }}

                    <fire-dept-check-form
                        :fire-depts="{{ fire_depts }}"
                        :record="{{ record|default(null)|json_encode }}"
                    ></fire-dept-check-form>

                    <br>
                    <hr>

                    <div class="buttons has-text-right is-grouped is-right" style="">
                        <button type="submit" class="button is-success"><i class="fas fa-check"></i>&nbsp;Сохранить</button>
                        <a href="{{ url('/fire-department-checks') }}" class="button is-light">Отменить</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock content %}
