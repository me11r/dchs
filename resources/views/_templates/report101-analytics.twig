    <span><b style="text-decoration: underline;">{{ date }} {{ city_area }}, {% if detailed_address %}<b> Уточненный адрес:</b> <span>{{ detailed_address }}</span>{% else %}{{ address }}{% endif %}</b>(заявитель: {{ caller_name }}, тел: {{ caller_phone }}).</span>
