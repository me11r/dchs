{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="panel">
            <div class="box">
                <h4 class="title">{{ title }}</h4>
                <form action="/dictionaries/{{ type }}/create-edit" method="post">
                    {{ csrf_field() }}
                    <input type="hidden" name="id" value="{{ record.id|default() }}"/>
                    <div class="field">
                        <label for="name">Позиция</label>
                        <input required type="text" class="input" name="position" id="position" value="{{ attribute(record, 'position')|default('') }}"/>
                    </div>

                    <div class="field">
                        <label for="city">Город</label>
                        <input required type="text" class="input" name="city" id="city" value="{{ attribute(record, 'city')|default('') }}"/>
                    </div>

                    <div class="field">
                        <label for="post">Пост</label>
                        <input required type="text" class="input" name="post" id="post" value="{{ attribute(record, 'post')|default('') }}"/>
                    </div>

                    <div class="field">
                        <label for="name">ФИО</label>
                        <input required type="text" class="input" name="name" id="name" value="{{ attribute(record, 'name')|default('') }}"/>
                    </div>

                    <div class="field">
                        <label for="type">Тип</label>
                        <select required name="type" id="type" class="select">
                            {% for key, item in types %}
                                <option {{ key == record.type|default(0) ? 'selected' : '' }} value="{{ key }}">{{ item }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="field">
                        <label for="type">Вид отчета</label>
                        <select required name="type" id="type" class="select">
                            {% for key, item in reportTypes %}
                                <option {{ key == record.report_type|default(0) ? 'selected' : '' }} value="{{ key }}">{{ item }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="buttons has-text-right is-grouped is-right" style="">
                        <button type="submit" class="button is-success"><i class="fas fa-check"></i>&nbsp;Сохранить</button>
                        <a href="/dictionaries/{{ type }}/" class="button is-light">Отменить</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock content %}
