{% extends "layout/html" %}
{% block content %}
    <div class="container">
        <div class="panel">
            <div class="level" style="margin: 10px 20px">
                <div class="level-left">
                    <h4 class="title">{{ title }}</h4>
                </div>
                <div class="level-right has-text-right">
                    <a href="{{ url(create_path) }}" class="button is-success"><i class="fas fa-plus"></i>&nbsp;Создать запись</a>
                </div>
                <div class="level-right has-text-left">
                    <a href="/dictionaries" class="button is-info"><i class="fas fa-backspace"></i>&nbsp;Назад</a>
                </div>
            </div>
            <table class="table is-striped is-narrow is-hoverable">
                <thead>
                <tr>
                    <th>№</th>
                    <th>Ранг пожара</th>
                    {#<th>Район города</th>#}
                    <th>Название объекта</th>
                    <th>Номер</th>
                    <th>ПЧ</th>
                    <th>Адрес</th>
                </tr>
                </thead>
                <tbody>
                {% for record in records %}
                    <tr>
                        <td>{{ record.id }}</td>
                        <td class="max-width: 20%">{{ record.fire_level.name|default('') }}</td>
                        {#<td class="max-width: 20%">{{ record.city_area.name|default('') }}</td>#}
                        <td class="max-width: 20%">{{ record.object_name|default('') }}</td>
                        <td class="max-width: 20%">{{ record.oc_number|default('') }}</td>
                        <td class="max-width: 20%">{{ record.fire_department.title|default('') }}</td>
                        <td class="max-width: 20%">{{ record.location|default('') }}</td>
                        <td>
                            <a href="{{ url(edit_path ~ record.id ~ '/' ~ 'edit') }}" class="button is-small is-primary is-outlined">
                                <i class="fas fa-edit"></i>&nbsp;Изменить
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td><h5 class="">Нет записей</h5></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% include "_templates/pagination" with {'items': records, 'per_page': per_page} %}
        </div>
    </div>
{% endblock content %}