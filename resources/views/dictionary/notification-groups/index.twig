{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="panel">
            <div class="level" style="margin: 10px 20px">
                <div class="level-left">
                    <h4 class="title">Группы личного состава</h4>
                </div>
                <div class="level-right has-text-right">
                    <a href="{{ route('notification-groups.create') }}" class="button is-basic is-main"><i class="fas fa-plus"></i>&nbsp;Создать запись</a>
                </div>
                <div class="level-right has-text-left">
                    <a href="/dictionaries" class="button is-info"><i class="fas fa-backspace"></i>&nbsp;Назад</a>
                </div>
            </div>
            <table class="table is-striped is-narrow is-hoverable" style="width: 100%">
                <thead>
                <tr>
                    <th>№</th>
                    <th>Название</th>
                    <th style="width: 50%">Состав</th>
                    <th>Действия</th>
                </tr>
                </thead>
                <tbody>
                {% for item in items %}
                    <tr>
                        <td>{{ item.id }}</td>
                        <td>{{ item.name }}</td>
                        <td>
                            <div class="tags">
                                {% for user in item.users %}
                                    <span class="tag is-success is-small">{{ user.full_username }}</span>
                                {% endfor %}
                            </div>
                        </td>
                        <td>
                            <form method="POST"
                                  onsubmit="return confirm('Вы действительно хотите удалить эту запись?');"
                                  action="{{ route('notification-groups.destroy', item.id) }}">
                                <input name="_method" type="hidden" value="DELETE">
                                {{ csrf_field() }}

                                <a href="{{ route('notification-groups.edit', item.id)  }}" class="button is-small is-primary is-outlined">
                                    <i class="fas fa-edit"></i>&nbsp;Изменить
                                </a>

                                <button type="submit"
                                        class="button is-small is-danger is-outlined">
                                    <i class="fas fa-trash"></i>&nbsp;Удалить
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td><h5 class="">Нет записей</h5></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            {% include "_templates/pagination" with {'items': items, 'per_page': per_page} %}
        </div>
    </div>
{% endblock content %}
