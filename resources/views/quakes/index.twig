{% extends "layout/html" %}
{% block content %}
    <div class="container-fluid section">
    <div class="level">
        <div class="level-left">
        <h4 class="title"
            style="padding: 3px 15px">ТОО СОМЭ
        </h4>
        </div>
        <div class="level-right">
                <a href="{{ route('quakes.create') }}" class="button is-main is-basic"
                   style="margin: 2px 10px 2px">
                    <i class="fas fa-plus"></i>&nbsp;Добавить
                </a>
        </div>
    </div>
    <div class="panel">
        <div class="levels">
            <div class="level-right">
                <a href="/quakes/export/xls" class="button is-success">Сохранить в XLS</a>
            </div>
        </div>
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>№</th>
                <th>Описание</th>
                <th>Дата и время Алматинского времени</th>
                <th>Дата и время по Гринвичу</th>
                <th>Эпицентр землетрясения</th>
                <th>Энергетический класс землетрясения</th>
                <th>Магнитуда MPV</th>
                <th>Координаты эпицентра</th>
                <th>Глубина</th>
                <th>Сведения об ощутимости</th>
                <th> &nbsp;</th>
            </tr>
            </thead>
            {% for item in items %}
                <tr>
                    <td class="has-text-right">{{ loop.index }}</td>
                    <td>{{ item.description }}</td>
                    <td>{{ item.date_almaty | date('d.m.Y H:i:s') }}</td>
                    <td>{{ item.date_greenwich | date('d.m.Y H:i:s') }}</td>
                    <td>{{ item.epicenter }}</td>
                    <td>{{ item.energy_class }}</td>
                    <td>{{ item.mpv }}</td>
                    <td>{{ item.coordinates }}</td>
                    <td>{{ item.deep }}</td>
                    <td>{{ item.information }}</td>
                    <td><div class="field is-grouped">
                            <a href="{{ route('quakes.edit', item.id) }}"
                               class="button is-small is-basic">
                                <i class="fas fa-pencil-alt"></i>&nbsp;
                                Редактировать
                            </a>

                            <form onsubmit="return confirm('Вы действительно хотите удалить эту запись?');"
                                  method="POST"
                                  action="{{ route('quakes.destroy', item.id) }}">
                                {{ csrf_field() }}
                                <input type="hidden" name="_method" value="DELETE">
                                <button title="Удалить"
                                        class="button is-small is-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </table>
    </div>
    </div>
{% endblock content %}
