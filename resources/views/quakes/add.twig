{% extends "layout/html" %}
{% block content %}
{#    <script src="https://api-maps.yandex.ru/2.1/?lang=ru-RU" type="text/javascript"></script>#}
    {% include "yandex/script.twig" %}
    <div class="container section" id="vue">
        <div class="panel">
            <div class="box" style="margin-top: 20px">
                <h4 class="title">{{ t('create_record') }}</h4>{#Добавить#}
                <form action="{{ route('quakes.store') }}" method="post">
                    {{ csrf_field() }}
                    <div class="field">
                        <label for="description">{{ t('description') }}</label>{#Описание#}
                        <textarea class="input" name="description" id="description" required></textarea>
                    </div>
                    <div class="field">
                        <label for="date_almaty">{{ t('/quakes.date_almaty') }}</label>{#Дата и время Алматинского времени#}
                        <input type="datetime-local" class="input" name="date_almaty" id="date_almaty" value="" required />
                    </div>
                    <div class="field">
                        <label for="date_greenwich">{{ t('/quakes.date_greenwich') }}</label>{#Дата и время по Гринвичу#}
                        <input type="datetime-local" class="input" name="date_greenwich" id="date_greenwich" value="" required />
                    </div>
                    <div class="field">
                        <label for="epicenter">{{ t('/quakes.epicenter') }}</label>{#Эпицентр землетрясения#}
                        <input type="text" class="input" name="epicenter" id="epicenter" value="" required/>
                    </div>
                    {#<div class="field">#}
                        {#<label for="energy_class">Энергетический класс землетрясения</label>#}
                        {#<input type="number" step="0.01" class="input" name="energy_class" id="energy_class" value="" required/>#}
                    {#</div>#}
                    <div class="field">
                        <label for="mpv">{{ t('/quakes.mpv') }}</label>{#Магнитуда MPV#}
                        <input type="number" step="0.01" class="input" name="mpv" id="mpv" value="" required/>
                    </div>
                    {#<div class="field">#}
                        {#<label for="coordinates">Координаты эпицентра</label>#}
                        {#<input type="text" class="input" name="coordinates" id="coordinates" value="" required/>#}
                    {#</div>#}
                    <div class="field">
                        <label for="deep">{{ t('/quakes.deep') }}</label>{#Глубина#}
                        <input type="number" step="0.01" class="input" name="deep" id="deep" value="" required/>
                    </div>
                    <div class="field">
                        <label for="information">{{ t('/quakes.information') }}</label>{#Сведения об ощутимости#}
                        <input type="text" class="input" name="information" id="information" value="" required/>
                    </div>
                    <quakes-form></quakes-form>
                    <div class="buttons has-text-right is-grouped is-right" style="">
                        <button type="submit" class="button is-success"><i class="fas fa-check"></i>&nbsp;{{ t('save') }}</button>{#Сохранить#}
                        <a href="{{ route('quakes.index') }}" class="button is-light">{{ t('cancel') }}</a>{#Отменить#}
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock content %}
