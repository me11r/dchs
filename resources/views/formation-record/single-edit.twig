{% extends "layout/html" %}

{% block content %}
    <div class="section {#container#}">
    <h4 class="title" style="padding: 3px 15px">Заполнение строевой записки {{ item.organisationName() }}</h4>

    <form action="{{ route('formation-record.update', item.id) }}" method="POST">
        <input type="hidden" name="_method" value="PATCH">
        {{ csrf_field() }}
        <div class="big-table-container">
            <table class="formation-record-table">
                <thead>
                <tr>
                    <th rowspan="3">Наименование подразеления</th>
                    <th colspan="3">Руководящий состав</th>
                    <th colspan="5">Личный состав</th>
                    <th colspan="8">Техника</th>
                    <th colspan="2">ГСМ</th>
                    <th rowspan="3">Радиостанции</th>
                    <th rowspan="3">Средства индивидуальной защиты органов дыхания</th>
                    <th rowspan="3">Средства индивидуальной защиты(Костюмы л1 и пр.)</th>
                    <th rowspan="3">Другие спасательные средства</th>
                </tr>
                <tr>
                    {#Личный состав#}
                    <th rowspan="2">Количество</th>
                    <th rowspan="2">Ф.И.О.</th>
                    <th rowspan="2">Телефон</th>

                    <th rowspan="2">По штату</th>
                    <th rowspan="2">В наличии</th>
                    <th colspan="3">На оперативном дежурстве</th>
                    {#Техника#}
                    <th colspan="2">Основная</th>
                    <th colspan="2">Специальная</th>
                    <th colspan="2">Вспомогательная</th>
                    <th colspan="2">Другая</th>
                    {#ГСМ#}
                    <th rowspan="2">Бензин</th>
                    <th rowspan="2">Дизтопливо</th>
                </tr>
                <tr>
                    {#Личный состав(подраздел)#}
                    <th>ФИО Старшего смены</th>
                    <th>Количество</th>
                    <th>8-ми часовом рабочем дне</th>
                    {# Техника #}
                    <th>На дежурстве(в боевом рассчете)</th>
                    <th>В резерве</th>
                    <th>На дежурстве(в боевом рассчете)</th>
                    <th>В резерве</th>
                    <th>На дежурстве(в боевом рассчете)</th>
                    <th>В резерве</th>
                    <th>На дежурстве(в боевом рассчете)</th>
                    <th>В резерве</th>
                </tr>
                </thead>
                <tbody>
                {% include 'formation-record/tr-form' with {item: item} %}
                </tbody>
            </table>


        </div>
        <div class="panel bottom_panel">
            <div class="level" style="padding-top: 2rem">
                <div class="level-left">&nbsp;</div>
                <div class="level-right">
                    <a href="{{ route('formation-record.single-index', item.organisation) }}"
                       style="margin-right: 10px"
                       class="button is-light">Назад</a>
                    <button
                            type="submit"
                            class="button is-success">
                        <i class="fas fa-check"></i>Сохранить
                    </button>
                </div>
            </div>
        </div>
    </form>

    </div>
{% endblock content %}
