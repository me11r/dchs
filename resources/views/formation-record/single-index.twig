{% extends "layout/html" %}
{% block content %}
    <div class="section container">
    <div class="level">
        <div class="level-left">
        <a href="{{ url('formation') }}" class="button is-light"><i class="fas fa-arrow-left"></i>&nbsp;К строевым запискам</a>
        <h4 class="title"
            style="padding: 3px 15px">Строевые записки {{ organisationName }}
        </h4>
        </div>
    </div>
    <div class="columns is-gapless">
        <div style="width: 100%; border-bottom: 1px solid #dbdbdb;">
        </div>
    </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th class="has-text-right" style="width: 110px">Дата и время</th>
                <th>&nbsp;</th>
            </tr>
            </thead>
            <tr>
                <td colspan="2"><a href="/formation-record/{{ organisation }}/create" class="button is-success is-fullwidth">Создать запись</a></td>
            </tr>
            {% for item in items %}
                <tr>
                    <td class="has-text-right">{{ item.date|date('Y-m-d') }}</td>
                    <td class="has-text-right">
                        {% if item.approved %}
                            <a href="#"
                               class="button is-small is-basic">
                                <i class="fas fa-glasses"></i>&nbsp;
                                Утверждено
                            </a>
                        {% else %}
                            <form method="post" action="/formation-record/approve/{{ item.id }}" style="display: inline">
                                {{ csrf_field() }}
                                <button onclick="return confirm('Утвердить?');"
                                        class="button is-small is-warning">
                                    <i class="fas fa-glasses"></i>&nbsp;
                                    Утвердить
                                </button>
                            </form>
                        {% endif %}
                        <a href="{{ route('formation-record.edit', item.id) }}"
                           class="button is-small is-basic">
                            <i class="fas fa-pencil-alt"></i>&nbsp;
                            Редактировать
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td class="is-centered"><h1 class="title">Нет записей</h1></td>
                </tr>
            {% endfor %}
        </table>
        {% include "_templates/pagination" with {'items': items, 'per_page': per_page} %}
    </div>
    </div>
{% endblock content %}
