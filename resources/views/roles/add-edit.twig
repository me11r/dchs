{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="panel">
            <div class="box" style="margin-top: 20px">
                <h4 class="title">{{ title }}</h4>
                <form action="{{ store_path }}" method="post">
                    {{ csrf_field() }}
                    <input type="hidden" name="id" value="{{ record.id|default() }}"/>
                    <div class="field">
                        <label for="name">Название</label>
                        <input required type="text" class="input" name="name" id="name" value="{{ attribute(record, 'name')|default('') }}"/>
                    </div>
                    <div class="field">
                        <label for="title">Наименование</label>
                        <input type="text" class="input" name="title" id="title" value="{{ attribute(record, 'title')|default('') }}"/>
                    </div>
                    <div class="col-md">
                        <h5 class="subtitle">Разрешения и роли</h5>
                        {% for group in right_groups %}
                            <h6 class="title">{{ group.title }}</h6>
                            {% for r in group.rights %}
                                <div class="form-check">
                                    <label for="right_{{ r.id }}" class="form-check-label">
                                        <input {% if record is defined and record.hasRight(r.id) %} checked {% endif %} type="checkbox" id="right_{{ r.id }}" name="right[{{ r.id }}]" value="{{ r.id }}"
                                               class="form-check-input"> {{ r.title|default('-?-') }}
                                    </label>
                                </div>
                            {% endfor %}
                            <br>
                        {% endfor %}
                    </div>

                    <div class="buttons has-text-right is-grouped is-right" style="">
                        <button type="submit" class="button is-success"><i class="fas fa-check"></i>&nbsp;Сохранить</button>
                        <a href="{{ back_path }}" class="button is-light">Отменить</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock content %}
