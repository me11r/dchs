{% extends "layout/html" %}
{% block content %}
    <div class="container section">
        <div class="level">
            <div class="level-left">
                <h3 class="title">Перемещения</h3>
            </div>
            <div class="level-right">
                <a href="{{ url('/formation/savers/migration/' ~ parent.id ~'/0') }}" class="button is-basic is-main"><i class="fas fa-plus"></i>&nbsp; Создать запись</a>
            </div>
        </div>
        <div>
            <table class="table is-narrow is-hoverable is-striped is-fullwidth">
                <thead>
                <tr>
                    <th>Направление</th>
                    <th>Ответственный</th>
                    <th>&nbsp;</th>
                </tr>
                </thead>
                <tbody>
                {% for report in reports %}
                    <tr>
                        <td>{{ report.from|default('') }} - {{ report.to|default('') }}</td>
                        <td>{{ report.manager_name|default('') }}</td>
                        <td class="has-text-right"><a href="{{ url('/formation/savers/migration/' ~ parent.id ~ '/' ~ report.id) }}" class="button is-basic is-small">
                                <i class="fas fa-edit"></i>&nbsp;Изменить
                            </a></td>
                    </tr>
                {% else %}
                    <tr>
                        <th colspan="3" class="has-text-centered"><h4 class="subtitle">Нет данных о перемещениях</h4></th>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock content %}
