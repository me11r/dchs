{% extends "layout/html" %}
{% block content %}
    <div class="container">
        <div class="level" style="margin-top: 20px">
            <div class="level-left">
        <h4 class="title">Техника строевой записки от {{ report.report_date }}</h4>
            </div>
            <div class="level-right">
                <a href="{{ url('/formation/add101persons/' ~ form_id ~ '/' ~ dept_id) }}" class="button is-"><i class="fas fa-user"></i>&nbsp;Данные персонала</a>
            </div>
        </div>
        <div class="field">
            <p class="control">
                <label for="dept_id_selector">Пожарная часть</label>
            <div class="select">
                <select class="select" name="dept_id" id="dept_id_selector">
                    {% for department in departments %}
                        <option value="{{ department.id }}" {% if department.id == dept_id %}selected{% endif %}>&nbsp;{{ department.title }}&nbsp;</option>
                    {% endfor %}
                </select>
            </div>
            </p>
        </div>
    </div>

    <script>
        window.addEventListener('load', () => {
            const selector = document.getElementById('dept_id_selector');
            const dept_id = '{{ dept_id }}';
            selector.addEventListener('change', (e) => {
                let location = window.location.pathname.split('/');
                location.pop();
                location.push(e.target.value);
                window.location = location.join('/');
            });
        });
    </script>
{% endblock content %}