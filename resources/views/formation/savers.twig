{% extends "layout/html" %}
{% block content %}
    <div class="level">
        <div class="level-left">
            <h4 class="title" style="padding: 3px 15px">Строевая записка ГУ «РОСО КЧС МВД РК»</h4>
        </div>
        {#
                <div class="level-right has-text-right"><a href="{{ url('formation/addToday') }}" class="button is-success is-outlined"  style="margin: 2px 10px 2px"><i class="fas fa-plus"></i>&nbsp;Новая строевая записка</a></div>
        #}
    </div>
    <table class="table is-fullwidth is-narrow is-hoverable">
        <thead>
        <tr>
            <th>
                Дата
            </th>
            <th>&nbsp;</th>
            <th>&nbsp;</th>
        </tr>
        </thead>
        {% for report in reports %}
            <tr class="{% if report.report_date == today %}is-primary{% else %}{% endif %}">
                <td>{{ report.report_date }}</td>
                <td class="has-text-right">
                    <a href="{{ url('/formation/savers/events/' ~ report.id) }}" class="button is-primary"><i class="fas fa-receipt"></i>&nbsp; Характерные спасоперации</a>
                    <a href="{{ url('/formation/savers/moving/' ~ report.id) }}" class="button is-primary"><i class="fas fa-receipt"></i>&nbsp; Перемещение подразделений</a>
                    <a href="{{ url('/formation/savers/people/' ~ report.id) }}" class="button is-primary"><i class="fas fa-receipt"></i>&nbsp; Изменить строевую записку</a>
                    <a href="{{ url('/formation/editsavers/' ~ report.id) }}" class="button is-primary"><i class="fas fa-receipt"></i>&nbsp; Изменить оперативную информацию</a>
                </td>
            </tr>
        {% endfor %}
    </table>
{% endblock content %}