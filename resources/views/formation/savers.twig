{% extends "layout/html" %}
{% block content %}
    <div class="container section">
    <div class="level">
        <div class="level-left">
            <a href="{{ url('formation') }}" class="button is-light"><i class="fas fa-arrow-left"></i>&nbsp;К строевым запискам</a>
            <h4 class="title" style="padding: 3px 15px">Строевая записка ГУ «РОСО КЧС МВД РК»</h4>
        </div>
        {#<div class="level-right has-text-right"><a href="{{ url('formation/addToday') }}" class="button is-success is-outlined"  style="margin: 2px 10px 2px"><i class="fas fa-plus"></i>&nbsp;Новая строевая записка</a></div>#}
    </div>
    <table class="table is-fullwidth is-narrow is-hoverable is-striped">
        <thead>
        <tr>
            <th>
                Дата
            </th>
            <th>&nbsp;</th>
            <th>&nbsp;</th>
        </tr>
        </thead>
        <tr>
            <td colspan="3"><a href="/formation-record/roso/create" class="button is-success is-fullwidth">Создать запись</a></td>
        </tr>
        {% for report in reports %}
            <tr class="{% if report.report_date == today %}is-primary{% else %}{% endif %}">
                <td>{{ report.report_date }}</td>
                <td class="has-text-right">
                    {% if auth.hasRight('CAN_ACCESS_FORMATION_REPORT_ROSO_EVENTS') %}
                        <a href="{{ url('/formation/savers/events/' ~ report.id) }}" class="button is-info is-small"><i class="fas fa-receipt"></i>&nbsp; Характерные спасоперации</a>
                    {% endif %}
                    {% if auth.hasRight('CAN_ACCESS_FORMATION_REPORT_ROSO_MIGRATIONS') %}
                        <a href="{{ url('/formation/savers/migrations/' ~ report.id) }}" class="button is-info is-small"><i class="fas fa-receipt"></i>&nbsp; Перемещение подразделений</a>
                    {#<a href="{{ url('/formation/savers/resources/' ~ report.id) }}" class="button is-primary"><i class="fas fa-receipt"></i>&nbsp; Изменить строевую записку</a>#}
                    {% endif %}
                    <a href="{{ url('formation-record/roso') }}" class="button is-basic is-small"><i class="fas fa-receipt"></i>&nbsp; Строевые записки</a>
                    {% if auth.hasRight('CAN_ACCESS_FORMATION_REPORT_ROSO_EDIT') %}
                        <a href="{{ url('/formation/editsavers/' ~ report.id) }}" class="button is-basic is-small"><i class="fas fa-receipt"></i>&nbsp; Изменить оперативную информацию</a>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
    </table>

    {% include "_templates/pagination" with {'items': reports, 'per_page': per_page} %}
    </div>
{% endblock content %}
