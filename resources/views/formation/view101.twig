{% extends "layout/html" %}
{% block content %}
    <div class="section container-fluid">
    <div class="panel">
        <div class="level" style="padding: 10px">
            <div class="level-left">
                <h4 class="title">Строевая записка от {{ report.report_date }}</h4>
            </div>
            <div class="level-right has-text-left">
                {% if user.hasRight(20) %}
                    {#{% if not report.is_approved %}#}
                        <form method="post" action="/formation/approve101/{{ report.id }}">
                            {{ csrf_field() }}
                            <button type="submit" class="button {{ report.is_approved ? 'is-disabled' : 'is-primary' }}"><i class="fas fa-adjust"></i>&nbsp; {{ report.is_approved ? 'Отменить утверждение' : 'Утвердить' }}</button>
                        </form>
                    {#{% else %}#}
                        {#<a class="button is-disabled" href="#">Утверждено</a>#}
                    {#{% endif %}#}
                {% endif %}
                {#<a style="margin: 10px;" target="_blank" href="/pdf/report101/pdf" class="button is-primary"><i class="fas fa-save"></i>&nbsp; Сохранить как PDF</a>#}
                <a style="margin: 5px 5px 5px 10px;" target="_blank" href="/pdf/report101/docx" class="button is-primary"><i class="fas fa-save"></i>&nbsp; Сохранить как DOCX</a>
                <a style="margin: 5px;" target="_blank" href="/pdf/report101/xls" class="button is-primary"><i class="fas fa-save"></i>&nbsp; Сохранить как XLS</a>
            </div>
        </div>
        <div class="level">
            <p class="">ДСПТ: {% for key, p in dept_od_people.dspt|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p class="">ЦППС: {% for key, p in dept_od_people.cpps|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p class="">ЕДДС: {% for key, p in dept_od_people.edds|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p class="">ИПЛ : {% for key, p in dept_od_people.ipl|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p class=""></p>
            <p class="">Водоканал: {% for key, p in dept_od_people.water_supply|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
        </div>

        <div class="tbl" style="overflow-x: scroll">
            <table id="main_table" class="detailed-table table is-small is-fullwidth is-narrow is-hoverable" style="font-size: .7rem">
                <thead>
                <tr>
                    <th class="rotate">
                        <div><span>П/Ч</span></div>
                    </th>
                    {% for key,hd_pp in people_fl %}
                        {% if hd_pp is iterable %}
                            {% for hd1_pp in hd_pp %}
                                <th class="rotate">
                                    <div><span>{{ key }}: {{ hd1_pp }}</span></div>
                                </th>
                            {% endfor %}
                        {% else %}
                            <th class="rotate">
                                <div><span>{{ hd_pp }}</span></div>
                            </th>
                        {% endif %}
                    {% endfor %}
                    {% for key,hd_pp in tech_fl %}
                        {% if hd_pp is iterable %}
                            {% for skey,hd1_pp in hd_pp %}
                                {% if hd1_pp is iterable %}
                                    {% for hd2_pp in hd1_pp %}
                                        <th class="rotate">
                                            <div><span>{{ key }}-{{ skey }}: {{ hd2_pp }}</span></div>
                                        </th>
                                    {% endfor %}
                                {% else %}
                                    <th class="rotate">
                                        <div><span>{{ key }}: {{ hd1_pp }}</span></div>
                                    </th>
                                {% endif %}
                            {% endfor %}
                        {% else %}
                            <th class="rotate">
                                <div><span>{{ hd_pp }}</span></div>
                            </th>
                        {% endif %}
                    {% endfor %}

                </tr>
                </thead>
                {% for dept in departments if dept.id != 13 %}
                    <tr {% if dept.tech_action|length == 0 %} style="background-color: #ff3317" {% endif %}>
                        <td>{{ dept.title }}</td>

                        {% for ppl in people_fields %}
                            <td>{{ people[dept.id][ppl]|default('-') }}</td>
                        {% endfor %}

                        {% for tch in tech_fields %}
                            <td>{{ tech[dept.id][tch]|default('-') }}</td>
                        {% endfor %}

                        <td>
                            {% for action in dept.tech_action %}
                                {{ action.vehicle.name|default('-') }}<br>
                            {% endfor %}
                        </td>
                        <td>
                            {% for action in dept.tech_action %}
                                {{ action.vehicle.base|default('-') }}<br>
                            {% endfor %}
                        </td>
                        <td>
                            {% for tech_reserve in dept.tech_reserve %}
                                {{ tech_reserve.vehicle.name|default('-') }}<br>
                            {% endfor %}
                        </td>
                        <td>
                            {% for tech_reserve in dept.tech_reserve %}
                                {{ tech_reserve.vehicle.base|default('-') }}<br>
                            {% endfor %}
                        </td>
                        <td>
                            {% for tech_repair in dept.tech_repair %}
                                {{ tech_repair.vehicle.name|default('-') }}<br>
                            {% endfor %}
                        </td>
                        <td>
                            {% for tech_repair in dept.tech_repair %}
                                {{ tech_repair.vehicle.base|default('-') }}<br>
                            {% endfor %}
                        </td>

                        {% for tch in tech_fields2 %}
                            <td>{{ tech[dept.id][tch]|default('-') }}</td>
                        {% endfor %}
                        <td>{{ tech[dept.id].head_guard.name|default('-') }}</td>
                    </tr>
                {% endfor %}

                <tr>
                    <td><b>Итого</b></td>
                    {% for ppl in people_fields %}
                        <td><b>{{ sumArray['people'][ppl]|default(0) }}</b></td>
                    {% endfor %}
                    {% for tch in tech_fields %}
                        <td>
                            <b>
                                {% if tch == 'field_4' %}
                                    -
                                {% else %}
                                    {{ sumArray['tech'][tch]|default(0) }}
                                {% endif %}
                            </b>
                        </td>
                    {% endfor %}
                    <td>
                        <b>
                            {{ tech_items_count.tech_action|default('0') }}
                        </b>
                    </td>
                    <td>
                        <b>
                            {{ tech_items_count.tech_action|default('0') }}
                        </b>
                    </td>
                    <td>
                        <b>
                            {{ tech_items_count.tech_reserve|default('0') }}
                        </b>
                    </td>
                    <td>
                        <b>
                            {{ tech_items_count.tech_reserve|default('0') }}
                        </b>
                    </td>
                    <td>
                        <b>
                            {{ tech_items_count.tech_repair|default('0') }}
                        </b>
                    </td>
                    <td>
                        <b>
                            {{ tech_items_count.tech_repair|default('0') }}
                        </b>
                    </td>

                    {% for item in ttl_count %}
                        <td>
                            <b>
                                {{ item }}
                            </b>
                        </td>
                    {% endfor %}
                </tr>

                {#{% for dept in excluded_departments %}#}
                    {#<tr>#}
                        {#<td>{{ dept.title }}</td>#}
                        {#{% for ppl in people_fields %}#}
                            {#<td>{{ people[dept.id][ppl]|default('-') }}</td>#}
                        {#{% endfor %}#}
                        {#{% for tch in tech_fields %}#}
                            {#<td>{{ tech[dept.id][tch]|default('-') }}</td>#}
                        {#{% endfor %}#}
                        {#<td>#}
                            {#{% for action in dept.tech_action %}#}
                                {#{{ action.vehicle.name|default('-') }}<br>#}
                            {#{% endfor %}#}
                        {#</td>#}
                        {#<td>-</td>#}
                        {#<td>#}
                            {#{% for tech_reserve in dept.tech_reserve %}#}
                                {#{{ tech_reserve.vehicle.name|default('-') }}<br>#}
                            {#{% endfor %}#}
                        {#</td>#}
                        {#<td>-</td>#}
                        {#<td>#}
                            {#{% for tech_repair in dept.tech_repair %}#}
                                {#{{ tech_repair.vehicle.name|default('-') }}<br>#}
                            {#{% endfor %}#}
                        {#</td>#}
                        {#<td>-</td>#}

                        {#{% for tch in tech_fields2 %}#}
                            {#<td>{{ tech[dept.id][tch]|default('-') }}</td>#}
                        {#{% endfor %}#}
                    {#</tr>#}
                {#{% endfor %}#}

            </table>
        </div>
        <div class="column">
            <p><span class="has-text-weight-bold">ЦРБ: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.crb|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">База ГДЗС: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.gdzs_base|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Врач: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.doctor|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
        </div>
        <div class="column">
            <h3 class="title" style="text-decoration: underline !important;">Посты ПЧ-13:</h3>
            <p><span class="has-text-weight-bold">1 пост: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> Резиденция Президента РК - {% for key, p in dept13_people.post1_president_residence|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">2 пост: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> Архив Президента РК - {% for key, p in dept13_people.post2_president_archive|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">3 пост: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> Государственный архив РК - {% for key, p in dept13_people.post3_state_archive|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">4 пост: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> Национальный Банк РК - {% for key, p in dept13_people.post4_national_bank|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
        </div>
        <div class="column">
            {#<h3 class="title" style="text-decoration: underline !important;">ОД:</h3>#}
            <h3 class="title" style="text-decoration: underline !important;">Оперативные дежурные автомашины:</h3>
            <p><span class="has-text-weight-bold">Тулпар-1: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar1|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Тулпар-2: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar2|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Тулпар-3: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar3|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Тулпар-4: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar4|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Тулпар-5: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar5|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Тулпар-7: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar7|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Тулпар-8: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar8|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">Тулпар-10: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.tulpar10|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">КШМ: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.kshm|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
            <p><span class="has-text-weight-bold">ИПЛ «Жалын»: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> {% for key, p in dept_od_people.ipl_zhalyn|default([]) %} {{ p.name ~ (not loop.last ? ', ' : '') }} {% endfor %}</p>
        </div>
    </div>
    </div>

    <style>
        th.rotate {
            /* Something you can count on */
            height: 255px;
            white-space: nowrap;
            font-size: .6rem;
        }

        th.rotate > div {
            transform: /* Magic3Numbers */ translate(25px, 151px) rotate(315deg);
            width: 30px;
        }

        th.rotate > div > span {
            border-bottom: 1px solid #ccc;
            padding: 5px 10px;
            margin: 0 0 0 -100px;
        }

        .detailed-table > thead {
        }

        .detailed-table tr > td {
            text-align: center;
            border-left: 1px solid #bbbfc3;
        }
    </style>
{% endblock content %}
