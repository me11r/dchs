{% extends "layout/html" %}
{% block content %}
    <div class="container">
        <div class="level">
            <div class="level-left">
                <h3 class="title">Строевая записка</h3>
            </div>
            <div class="level-right">
                <a href="{{ url('/formation/savers/resource/' ~ parent.id ~'/0') }}" class="button is-success is-outlined"><i class="fas fa-plus"></i>&nbsp; Создать запись</a>
            </div>
        </div>
        <div>
            <table class="table is-narrow is-hoverable is-striped is-fullwidth">
                <thead>
                <tr>
                    <th>Описание</th>
                    <th>&nbsp;</th>
                </tr>
                </thead>
                <tbody>
                {% for report in reports %}
                    <tr>
                        <td>{{ report.formation|default('') }}</td>
                        <td class="has-text-right"><a href="{{ url('/formation/savers/resource/' ~ parent.id ~ '/' ~ report.id) }}" class="button is-primary is-small is-outlined">
                                <i class="fas fa-edit"></i>&nbsp;Изменить
                            </a></td>
                    </tr>
                {% else %}
                    <tr>
                        <th colspan="3" class="has-text-centered"><h4 class="subtitle">Нет данных о силах и средствах</h4></th>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock content %}