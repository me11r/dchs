{% extends "layout/html" %}
{% block content %}
    <div class="columns is-centered">
        <div class="is-half-desktop column is-gapless">
            <div class="" style="padding: 32px;">
                {% if has_today %}
                    <div class="message box">
                        <div class="message-header is-warning">Строевая записка на этот день ({{ today }}) уже существует!</div>
                        <div class="message-body has-text-centered">
                            <div class="buttons is-grouped is-grouped-centered">
                                <a href="{{ url('formation/add101persons/' ~ report.0.id ~ '/1') }}" class="button is-primary is-outlined"><i class="fas fa-user"></i>&nbsp; Персонал</a>
                                <a href="{{ url('formation/add101tech/' ~ report.0.id ~ '/1') }}" class="button is-primary is-outlined"><i class="fas fa-truck"></i>&nbsp; Техника</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="message">
                        <div class="message-header is-primary">
                            Создать строевую записку на дату {{ today }} ?
                        </div>
                        <form action="" method="post">
                            {{ csrf_field() }}
                            <div class="message-body">
                                <div class="buttons has-text-right is-grouped is-right">
                                    <button type="submit" class="button is-success"><i class="fas fa-plus"></i>&nbsp;Создать</button>
                                    <a href="{{ url('/formation/101') }}" class="button is-light">Отменить</a>
                                </div>
                            </div>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock content %}