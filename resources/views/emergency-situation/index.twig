{% extends "layout/html" %}
{% block content %}
    <div class="">
        <h4 class="title"
            style="padding: 3px 15px">Оперативная информация
        </h4>
    </div>
    <div class="columns is-gapless">
        <div style="width: 100%; border-bottom: 1px solid #dbdbdb;">
        </div>
        <div class="column is-narrow">
            <div style="border-bottom: 1px solid #dbdbdb">
                <a href="{{ route('emergency-situation.create') }}" class="button is-success is-outlined"
                   style="margin: 2px 10px 2px">
                    <i class="fas fa-plus"></i>&nbsp;Добавить
                </a>
            </div>
        </div>
    </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>Дата и время</th>
                <th>Место происшествия</th>
                <th>Характер и масштаб</th>
                <th>&nbsp;</th>
            </tr>
            </thead>
            {% for item in items %}
                <tr>
                    <td class="has-text-right">{{ item.date|date('Y-m-d') }} {{ item.time }}</td>
                    <td>{{ item.location }}</td>
                    <td>{{ item.size }}</td>
                    <td class="has-text-right">
                        <a href="{{ route('emergency-situation.show', item.id) }}"
                           class="button is-small is-outlined is-success">
                            <i class="fas fa-eye"></i>&nbsp;
                            Просмотр
                        </a>
                        <a href="{{ route('emergency-situation.edit', item.id) }}"
                           class="button is-small is-outlined is-primary">
                            <i class="fas fa-pencil-alt"></i>&nbsp;
                            Редактировать
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td class="is-centered"><h1 class="title">Нет записей</h1></td>
                </tr>
            {% endfor %}
        </table>
    </div>
{% endblock content %}
