{% extends "layout/html" %}
{% block content %}
    <script>
        window.ticket101add = {
            records: {{ ticket.other_records | json_encode() | raw }},
            trunks: {{ trunks | json_encode() | raw }}
        };
    </script>

    <section class="container" id="cardadd101">
        <div class=""><h4 class="title" style="padding: 3px 15px">Добавление: Карточка 101</h4></div>
        <form action="" method="post">
            {{ csrf_field() }}
            <div class="tabs is-boxed" id="">
                <ul>
                    <li><a href="#tab_call" onclick="window.add101tabs.setTab(0);"><i class="fas fa-phone"></i>&nbsp;Звонок</a>
                    </li>
                    <li>
                        <a href="#tab_truck" onclick="window.add101tabs.setTab(1);">
                            <i class="fas fa-truck-moving"></i>&nbsp;Подразделения
                        </a>
                    </li>
                    <li><a href="#tab_notify" onclick="window.add101tabs.setTab(2);"><i class="fas fa-envelope"></i>&nbsp;Уведомления</a>
                    </li>
                    <li>
                        <a href="#tab_other" onclick="window.add101tabs.setTab(3);"><i class="fas fa-info-circle"></i>&nbsp;
                            Прочее
                        </a>
                    </li>
                    <li>
                        <a href="#tab_summary" onclick="window.add101tabs.setTab(4);">
                            <i class="fas fa-check-double"></i>&nbsp;Итоги выезда
                        </a>
                    </li>
                </ul>
            </div>
            <div id="preload_pane" class="hero is-loading has-text-centered" style="height: 30vh; align-items: center">
                <div class="hero-body has-text-info">
                    <i class="fas fa-circle-notch fa-spin fa-6x"></i>
                </div>
            </div>
            <div class="panels">
                <div id="tab_call" class="is-hidden">
                    <h5 class="subtitle">Сведения поступившие со звонком:</h5>
                    {% if ticket.id %}
                        <div class="level is-marginless">
                            <div class="level-left">
                                <label>Номер КУИ:</label>&nbsp;{{ ticket.id }}
                            </div>
                        </div>
                    {% endif %}
                    <div class="field" data-component="location-input" data-value="{{ ticket.location|default('') }}">
                        <label for="location">Место пожара (Адрес)</label>
                        <textarea name="location"
                                  id="location"
                                  class="textarea"
                                  cols="30"
                                  v-model="location"
                                  rows="3">
                        </textarea>
                    </div>
                    <div class="field">
                        <p class="control">
                            <label for="city_area">Район города</label>
                        </p>
                        <div class="select"
                             data-component="simple-select"
                             data-special="specialPlan"
                             data-value="{{ ticket.city_area_id }}"
                             data-name="city_area_id">
                            <select name="city_area_id" id="city_area" v-model="selectedId">
                                <option value="">-</option>
                                {% for area in city_area %}
                                    <option value="{{ area.id }}">{{ area.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="field is-grouped">
                        <div class="control is-expanded" data-component="autocomplete"
                             data-name="{{ ticket.crossroad_1.name|default('') }}"
                             data-hid="{{ ticket.crossroad_1_id|default('') }}">
                            <label for="crossroad_1_id">Пересечение улицы</label>
                            <input type="hidden" name="crossroad_1_id" id="crossroad_1_hid" :value="hid"/>
                            <b-autocomplete
                                    field="name"
                                    ref="crossroad_1_hid"
                                    id="crossroad_1_id"
                                    v-model="name"
                                    :data="data"
                                    :loading="isFetching"
                                    @input="getData"
                                    @select="onSelect"
                            >
                                <template slot-scope="props">
                                    {% verbatim %}
                                    <div class="row"><span>{{ props.option.name }}</span><small v-if="props.option.area">, {{ props.option.area.name }} район</small></div>
                                    {% endverbatim %}
                                </template>
                                <template slot="empty">Подходящих улиц не найдено</template>
                            </b-autocomplete>
                        </div>
                        <div class="control is-expanded" data-component="autocomplete"
                             data-name="{{ ticket.crossroad_2.name|default('') }}"
                             data-hid="{{ ticket.crossroad_2_id|default('') }}">
                            <label for="crossroad_2_id">и улицы</label>
                            <input type="hidden" name="crossroad_2_id" id="crossroad_2_hid" :value="hid"/>
                            <b-autocomplete type="text" id="crossroad_2_id"
                                            field="name"
                                            ref="crossroad_2_hid"
                                            id="crossroad_2_id"
                                            v-model="name"
                                            :data="data"
                                            :loading="isFetching"
                                            @input="getData"
                                            @select="onSelect"
                            >
                                <template slot-scope="props">
                                    {% verbatim %}
                                    <div class="row"><span>{{ props.option.name }}</span><small v-if="props.option.area">, {{ props.option.area.name }} район</small></div>
                                    {% endverbatim %}
                                </template>
                                <template slot="empty">Подходящих улиц не найдено</template>

                            </b-autocomplete>
                        </div>
                    </div>

                    <div class="field">
                        <div class="control">
                            <label for="pre_information_id">Предварительная информация</label>
                        </div>
                        <div class="select"
                             data-component="simple-select"
                             data-value="{{ ticket.pre_information_id }}"
                             data-name="pre_information_id"
                             style="width:50%; padding-right: 6px;">
                            <select name="pre_information_id"
                                    id="pre_information_id"
                                    v-model="selectedId"
                                    style="width: 100%"
                                    required>
                                <option value="">-</option>
                                {% for object in fire_object_options %}
                                    <option value="{{ object.id }}">{{ object.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <p class="control">
                            <label for="fire_object_id">Что горит</label>
                        </p>
                        <div class="select" style="width:50%; padding-right: 6px;">
                            <select name="fire_object_id"
                                    id="fire_object_id"
                                    style="width: 100%">
                                <option value="">-</option>
                                {% for object in fire_object %}
                                    <option value="{{ object.id }}"
                                            {% if object.id == ticket.fire_object_id %}selected{% endif %}>{{ object.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="field is-grouped">
                        <p class="control"
                           data-component="object-name-input"
                           data-value="{{ ticket.object_name|default('') }}">
                            <label for="object_name">Наименование объекта</label>
                            <input type="text"
                                   class="input"
                                   name="object_name"
                                   id="object_name"
                                   v-model="object_name"
                                   required/>
                        </p>

                        <p class="control"
                           data-component="buefy-common-select"
                           data-name="operational_plan_id"
                           data-value="{{ ticket.operational_plan_id|default(0) }}">
                            <label for="operational_plan_id">Оперативный план</label>
                            <input type="hidden"
                                   name="operational_plan_id"
                                   id="operational_plan_id"
                                   v-model="selectedId">
                            <buefy-common-select
                                    :options='{{ operational_plans | json_encode() | raw }}'
                                    :min-length="1"
                                    v-model="selectedId">
                            </buefy-common-select>
                        </p>

                        <div class="control">
                            <label for="fire_level_id">Ранг пожара</label>
                            <div class="select"
                                 data-component="simple-select"
                                 data-special="specialPlan"
                                 data-value="{{ ticket.fire_level_id }}"
                                 data-name="fire_level_id"
                                 style="display: block">
                                <select name="fire_level_id" id="fire_level_id" v-model="selectedId">
                                    <option value="">-</option>
                                    {% for object in fire_levels %}
                                        <option value="{{ object.id }}">{{ object.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <p class="control"
                           data-name="fire_department_id"
                           data-component="buefy-common-select"
                           data-value="{{ ticket.fire_department_id|default(0) }}">
                            <label for="fire_department_id">Микроучасток</label>
                            <input type="hidden"
                                   name="fire_department_id"
                                   id="fire_department_id"
                                   v-model="selectedId">
                            <buefy-common-select
                                    :options='{{ fire_departments | json_encode() | raw }}'
                                    :min-length="1"
                                    v-model="selectedId">
                            </buefy-common-select>
                        </p>
                    </div>

                    <div class="field">
                        <div class="checkbox">
                            <input type="hidden" name="people_in_danger" value="0"/>
                            <input type="checkbox" name="people_in_danger" value="1" id="people_in_danger"
                                   {% if ticket.people_in_danger %}checked{% endif %}/>
                            <label for="people_in_danger">Опасность для людей</label>
                        </div>
                    </div>
                    <div class="field is-grouped">
                        <p class="control">
                            <label for="storey_count">Этажность</label>
                            <input type="number" class="input" name="storey_count" id="storey_count"
                                   value="{{ ticket.storey_count|default('') }}"/>
                        </p>
                        <p class="control">
                            <label for="floor">На каком этаже пожар</label>
                            <input type="number" class="input" name="floor" id="floor"
                                   value="{{ ticket.floor|default('') }}"/>
                        </p>
                    </div>
                    <div class="field">
                        <label for="building_description">Конструктивные особенности</label>
                        <textarea class="textarea" name="building_description" id="building_description" cols="30"
                                  rows="2">{{ ticket.building_description|default('') }}</textarea>
                    </div>
                    <div class="field is-grouped">
                        <p class="control is-expanded">
                            <label for="caller_name">ФИО Заявителя</label>
                            <input type="text" class="input" name="caller_name" id="caller_name"
                                   value="{{ ticket.caller_name|default('') }}"/>
                        </p>
                        <p class="control">
                            <label for="caller_phone">Телефон заявителя</label>
                            <input type="text" class="input" name="caller_phone" id="caller_phone"
                                   value="{{ ticket.caller_phone|default('') }}"/>
                        </p>
                    </div>
                    <div class="field">
                        <div id="control" data-component="timepicker"
                             data-value="{{ attribute(ticket, 'register_time')|default(date().format('H:i')) }}">
                            <label for="register_time">Время регистрации сообщения</label>
                            <b-timepicker icon="clock" icon-pack="far" @focus="closeAll()" type="text" v-model="value"
                                          style="max-width: 6rem;" name="register_time" :value="value">
                                <div class="field is-grouped" style="justify-content: space-between">
                                    <p class="control">
                                        <a class="button is-primary is-small"
                                           @click="()=> {value = new Date(); close();}">
                                            <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                            <span>Сейчас</span>
                                        </a>
                                    </p>
                                    <p class="control">
                                        <a class="button is-outlined is-small" @click="close()">
                                            <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                        </a>
                                    </p>
                                </div>
                            </b-timepicker>
                        </div>
                    </div>
                </div>
                <div id="tab-truck" class="is-hidden">
                    <h5 class="subtitle">Время выезда, прибытия, возвращения подразделений:</h5>
                    <table class="table is-narrow is-hoverable is-striped is-fullwidth">
                        <tr>
                            <th>Подразделение</th>
                            <th>Отделения</th>
                            <th>Время выезда</th>
                            <th>- прибытия</th>
                            <th>- локализации</th>
                            <th>- ликвидации</th>
                            <th>- возвращения</th>
                            <th>-</th>
                        </tr>
                        {% for index,ssv in ssv_out %}
                            <tr>
                                <td class="has-text-right">{{ ssv }}</td>
                                <td><input class="input" type="text" name="ph_{{ index }}_ot" id="ph_{{ index }}_ot"
                                           value="{{ attribute(ticket,  'ph_' ~ index ~'_ot')|default('') }}"/></td>
                                <td data-component="timepicker"
                                    data-value="{{ attribute(ticket,  'ph_' ~ index ~'_out_time')|default('') }}">
                                    <b-timepicker @focus="closeAll()" icon="clock" icon-pack="far" type="text"
                                                  name="ph_{{ index }}_out_time" id="ph_{{ index }}_out_time"
                                                  :value="value">
                                        <div class="field is-grouped" style="justify-content: space-between">
                                            <p class="control">
                                                <a class="button is-primary is-small"
                                                   @click="()=> {value = new Date(); close();}">
                                                    <b-icon pack="far" icon="clock"></b-icon>
                                                    <span>Сейчас</span>
                                                </a>
                                            </p>
                                            <p class="control">
                                                <a class="button is-outlined is-small" @click="close()">
                                                    <i class="fas fa-check"></i><span>Принять</span>
                                                </a>
                                            </p>
                                        </div>
                                    </b-timepicker>
                                </td>
                                <td data-component="timepicker"
                                    data-value="{{ attribute(ticket,  'ph_' ~ index ~'_arrive_time')|default('') }}">
                                    <b-timepicker @focus="closeAll()" icon="clock" icon-pack="far" type="text"
                                                  name="ph_{{ index }}_arrive_time" id="ph_{{ index }}_arrive_time"
                                                  :value="value">
                                        <div class="field is-grouped" style="justify-content: space-between">
                                            <p class="control">
                                                <a class="button is-primary is-small"
                                                   @click="()=> {value = new Date(); close();}">
                                                    <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                                    <span>Сейчас</span>
                                                </a>
                                            </p>
                                            <p class="control">
                                                <a class="button is-outlined is-small" @click="close()">
                                                    <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                                </a>
                                            </p>
                                        </div>
                                    </b-timepicker>
                                </td>
                                <td data-component="timepicker"
                                    data-value="{{ attribute(ticket,  'ph_' ~ index ~'_loc_time')|default('') }}">
                                    <b-timepicker @focus="closeAll()" icon="clock" icon-pack="far" type="text"
                                                  name="ph_{{ index }}_loc_time" id="ph_{{ index }}_loc_time"
                                                  :value="value">
                                        <div class="field is-grouped" style="justify-content: space-between">
                                            <p class="control">
                                                <a class="button is-primary is-small"
                                                   @click="()=> {value = new Date(); close();}">
                                                    <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                                    <span>Сейчас</span>
                                                </a>
                                            </p>
                                            <p class="control">
                                                <a class="button is-outlined is-small" @click="close()">
                                                    <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                                </a>
                                            </p>
                                        </div>
                                    </b-timepicker>
                                </td>
                                <td data-component="timepicker"
                                    data-value="{{ attribute(ticket,  'ph_' ~ index ~'_liqv_time')|default('') }}">
                                    <b-timepicker @focus="closeAll()" icon="clock" icon-pack="far" type="text"
                                                  name="ph_{{ index }}_liqv_time" id="ph_{{ index }}_liqv_time"
                                                  :value="value">
                                        <div class="field is-grouped" style="justify-content: space-between">
                                            <p class="control">
                                                <a class="button is-primary is-small"
                                                   @click="()=> {value = new Date(); close();}">
                                                    <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                                    <span>Сейчас</span>
                                                </a>
                                            </p>
                                            <p class="control">
                                                <a class="button is-outlined is-small" @click="close()">
                                                    <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                                </a>
                                            </p>
                                        </div>
                                    </b-timepicker>
                                </td>
                                <td data-component="timepicker"
                                    data-value="{{ attribute(ticket,  'ph_' ~ index ~'_ret_time')|default('') }}">
                                    <b-timepicker @focus="closeAll()" icon="clock" icon-pack="far" type="text"
                                                  name="ph_{{ index }}_ret_time" id="ph_{{ index }}_ret_time"
                                                  :value="value">
                                        <div class="field is-grouped" style="justify-content: space-between">
                                            <p class="control">
                                                <a class="button is-primary is-small"
                                                   @click="()=> {value = new Date(); close();}">
                                                    <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                                    <span>Сейчас</span>
                                                </a>
                                            </p>
                                            <p class="control">
                                                <a class="button is-outlined is-small" @click="close()">
                                                    <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                                </a>
                                            </p>
                                        </div>
                                    </b-timepicker>
                                </td>
                                <td>
                                    {% if attribute(ticket, 'ph_' ~ index ~ '_dispatched') == 0 %}
                                        <a href="{{ url('/roadtrip/send/'~index ~'/'~ticket.id) }}"
                                           class="button is-primary is-outlined"><i class="fas fa-bus"></i>&nbsp;Отправить
                                            подразделение</a>
                                    {% else %}
                                        <span class="button is-disabled is-outlined"><i class="fas fa-bus"></i>&nbsp; Подраздение отправлено</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </table>
                </div>
                <div id="tab_notify" class="is-hidden">
                    <h5 class="subtitle">Время сообщения руководству ГУ:</h5>
                    <div class="field is-grouped">
                        {% for name,title in gu_notify %}
                            <div class="control" data-component="timepicker"
                                 data-value="{{ attribute(ticket, 'notify_' ~ name ~ '_time')| default('') }}">
                                <label for="notify_{{ name }}_time">{{ title }}</label>
                                <b-timepicker @focus="closeAll()" type="text" v-model="value" style="max-width: 4rem"
                                              name="notify_{{ name }}_time" :value="value" id="notify_{{ name }}_time">
                                    <div class="field is-grouped" style="justify-content: space-between">
                                        <p class="control">
                                            <a class="button is-primary is-small"
                                               @click="()=> {value = new Date(); close();}">
                                                <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                                <span>Сейчас</span>
                                            </a>
                                        </p>
                                        <p class="control">
                                            <a class="button is-outlined is-small" @click="close()">
                                                <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                            </a>
                                        </p>
                                    </div>
                                </b-timepicker>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="field" data-component="timepicker"
                         data-value="{{ ticket.next_notify_time|default('') }}">
                        <label for="next_notify_time">Время следующего взаимодействия</label>
                        <b-timepicker @focus="closeAll()" v-model="value" type="text" style="max-width: 4rem"
                                      name="next_notify_time" id="next_notify_time" :value="value">
                            <div class="field is-grouped" style="justify-content: space-between">
                                <p class="control">
                                    <a class="button is-primary is-small"
                                       @click="()=> {value = new Date(); close();}">
                                        <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                        <span>Сейчас</span>
                                    </a>
                                </p>
                                <p class="control">
                                    <a class="button is-outlined is-small" @click="close()">
                                        <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                    </a>
                                </p>
                            </div>
                        </b-timepicker>
                    </div>
                    <h5 class="subtitle">Службы</h5>
                    <div>
                        <table class="table is-expanded is-striped is-narrow is-fullwidth">
                            <thead>
                            <tr>
                                <th>Службы</th>
                                <th>Время сообщения</th>
                                <th>Фамилия<br/>принявшего сообщение</th>
                                <th>Время прибытия</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for name,title in service_notify %}
                                <tr>
                                    <td>{{ title }}</td>
                                    <td data-component="timepicker"
                                        data-value="{{ attribute(ticket, 'call_' ~  name  ~ '_time')|default('') }}">
                                        <b-timepicker @focus="closeAll()" class="is-rounded" type="text"
                                                      name="call_{{ name }}_time" id="call_{{ name }}_time"
                                                      :value="value" icon="clock" icon-pack="far">
                                            <div class="field is-grouped" style="justify-content: space-between">
                                                <p class="control">
                                                    <a class="button is-primary is-small"
                                                       @click="()=> {value = new Date(); close();}">
                                                        <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                                        <span>Сейчас</span>
                                                    </a>
                                                </p>
                                                <p class="control">
                                                    <a class="button is-outlined is-small" @click="close()">
                                                        <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                                    </a>
                                                </p>
                                            </div>
                                        </b-timepicker>
                                    </td>
                                    <td><input type="text" class="input" name="name_{{ name }}_recv"
                                               id="name_{{ name }}_recv"
                                               value="{{ attribute(ticket, 'name_' ~  name  ~ '_recv')|default('') }}"/>
                                    </td>
                                    <td data-component="timepicker"
                                        data-value="{{ attribute(ticket, 'arrival_' ~  name )|default('') }}">
                                        <b-timepicker @focus="closeAll()" icon="clock" icon-pack="far" type="text"
                                                      name="arrival_{{ name }}" id="arrival_{{ name }}"
                                                      :value="value">
                                            <div class="field is-grouped" style="justify-content: space-between">
                                                <p class="control">
                                                    <a class="button is-primary is-small"
                                                       @click="()=> {value = new Date(); close();}">
                                                        <b-icon pack="far" icon="clock"></b-icon>&nbsp;
                                                        <span>Сейчас</span>
                                                    </a>
                                                </p>
                                                <p class="control">
                                                    <a class="button is-outlined is-small" @click="close()">
                                                        <i class="fas fa-check"></i>&nbsp;<span>Принять</span>
                                                    </a>
                                                </p>
                                            </div>
                                        </b-timepicker>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div id="tab_other" class="is-hidden">
                    <h5 class="subtitle">Обстановка с места пожара:</h5>
                    <div id="ticket101_other_records"></div>
                    <div class="field">
                        <label for="add_info">Дополнительная информация</label>
                        <textarea name="add_info" id="add_info" class="textarea" cols="30" rows="3"></textarea>
                    </div>
                </div>
                <div id="tab_summary" class="is-hidden">
                    <div class="field">
                        <label for="detailed_address">Уточненный адрес</label>
                        <textarea name="detailed_address" id="detailed_address" cols="30" rows="3"
                                  class="textarea"></textarea>
                    </div>
                    <div class="field">
                        <div class="control">
                            <label for="burn_object_id">Объект горения</label>
                        </div>
                        <div class="select">
                            <select name="burn_object_id" id="burn_object_id">
                                <option value=""> -</option>
                                {% for burn in burn_object %}
                                    <option value="{{ burn.id }}"
                                            {% if burn.id == ticket.burn_object_id %}selected{% endif %}>{{ burn.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <div class="control">
                            <label for="trip_result_id">Результат выезда</label>
                        </div>
                        <div class="select">
                            <select name="trip_result_id" id="trip_result_id">
                                <option value=""> -</option>
                                {% for trip_res in trip_result %}
                                    <option value="{{ trip_res.id }}"
                                            {% if trip_res.id == ticket.trip_result_id %}selected{% endif %}>{{ trip_res.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <div class="control">
                            <label for="liquidation_method_id">Потушено стволами</label>
                        </div>
                        <div class="select">
                            <select name="liquidation_method_id" id="liquidation_method_id">
                                <option value="">-</option>
                                {% for liquidation_method in liquidation_methods %}
                                    <option value="{{ liquidation_method.id }}"
                                            {% if liquidation_method.id == ticket.liquidation_method_id %}selected{% endif %}>{{ liquidation_method.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <div class="control">
                            <label for="result_fire_level_id">Уточненный ранг пожара</label>
                        </div>
                        <div class="select">
                            <select name="result_fire_level_id" id="result_fire_level_id">
                                <option value="">-</option>
                                {% for fire_level in fire_levels %}
                                    <option value="{{ fire_level.id }}"
                                            {% if fire_level.id == ticket.result_fire_level_id %}selected{% endif %}>{{ fire_level.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="field is-grouped">
                        <div class="control">
                            <div class="checkbox">
                                <input type="hidden" name="vu_found" value="0"/>
                                <input type="checkbox" name="vu_found" id="vu_found" value="1"
                                       {% if ticket.vu_found == 1 %}checked{% endif %}/>
                                <label for="vu_found">Обнаружено ВУ</label>
                            </div>
                        </div>
                        <div class="control">
                            <div class="checkbox">
                                <input type="hidden" name="animal_death" value="0"/>
                                <input type="checkbox" name="animal_death" id="animal_death" value="1"
                                       {% if ticket.animal_death == 1 %}checked{% endif %}/>
                                <label for="animal_death">Гибель животных</label>
                            </div>
                        </div>
                        <div class="control">
                            <div class="checkbox">
                                <input type="hidden" name="car_crash" value="0"/>
                                <input type="checkbox" name="car_crash" id="car_crash" value="1"
                                       {% if ticket.car_crash == 1 %}checked{% endif %}/>
                                <label for="car_crash">Авария А/М при следовании на пожар, с жертвами</label>
                            </div>
                        </div>

                    </div>
                    <div class="field is-grouped">
                        <div class="control">
                            <label for="rescued_count">Спасено людей
                            </label>
                            <input type="number" class="input" name="rescued_count" id="rescued_count"
                                   value="{{ ticket.rescued_count|default('') }}"/>
                        </div>
                        <div class="control">
                            <label for="evac_count">Эвакуировано людей
                            </label>
                            <input type="number" class="input" name="evac_count" id="evac_count"
                                   value="{{ ticket.evac_count|default('') }}"/>
                        </div>

                        <div class="control">
                            <label for="co2_poisoned_count">Получили отравления угарным газом
                            </label>
                            <input type="number" class="input" name="co2_poisoned_count" id="co2_poisoned_count"
                                   value="{{ ticket.co2_poisoned_count|default('') }}"/>
                        </div>
                        <div class="control">
                            <label for="ch4_poisoned_count">Получили отравления природным газом
                            </label>
                            <input type="number" class="input" name="ch4_poisoned_count" id="ch4_poisoned_count"
                                   value="{{ ticket.ch4_poisoned_count|default('') }}"/>
                        </div>

                    </div>
                    <div class="field is-grouped">
                        <div class="control">
                            <label for="gpt_burns_count">Получили ожоги
                            </label>
                            <input type="number" class="input" name="gpt_burns_count" id="gpt_burns_count"
                                   value="{{ ticket.gpt_burns_count|default('') }}"/>
                        </div>

                        <div class="control">
                            <label for="people_death_count">Гибель людей
                            </label>
                            <input type="number" class="input" name="people_death_count" id="people_death_count"
                                   value="{{ ticket.people_death_count|default('') }}"/>
                        </div>
                        <div class="control">
                            <label for="children_death_count">Гибель детей
                            </label>
                            <input type="number" class="input" name="children_death_count" id="children_death_count"
                                   value="{{ ticket.children_death_count|default('') }}"/>
                        </div>
                        <div class="control">
                            <label for="hospitalized_count">Госпитализировано
                            </label>
                            <input type="number" class="input" name="hospitalized_count" id="hospitalized_count"
                                   value="{{ ticket.hospitalized_count|default('') }}"/>
                        </div>
                    </div>
                    <div class="field">
                        <label for="more_info">Дополнительная информация</label>
                        <textarea name="more_info" id="more_info" cols="30" rows="2"
                                  class="textarea">{{ ticket.more_info|default('') }}</textarea>
                    </div>
                    <div class="field">
                        <div class="checkbox">
                            <input type="hidden" name="hydrant_found" value="0"/>
                            <input type="checkbox" name="hydrant_found" id="hydrant_found" value="1"
                                   {% if ticket.hydrant_found == 1 %}checked{% endif %}/>
                            <label for="hydrant_found">Наличие ПГ/ПВ</label>
                        </div>
                    </div>
                    <div class="field">
                        <div class="control">
                            <label for="distance">Расстояние до места
                            </label>
                            <input type="number" class="input" name="distance" id="distance"
                                   value="{{ ticket.distance|default('') }}"/>
                        </div>
                    </div>
                    <div class="field">
                        <label for="owner">Владелец(дома,кв.,а/м)</label>
                        <input type="text" id="owner" name="owner" value="{{ ticket.owner|default('') }}"
                               class="input"/>
                    </div>
                    <h5 class="subtitle">Объяснения</h5>
                    <div class="field">
                        <div class="file is-info has-name">
                            <label class="file-label">
                                <input class="file-input" type="file">
                                <span class="file-cta">
                                    <span class="file-icon">
                                        <i class="fas fa-upload"></i>
                                    </span>
                                    <span class="file-label">
                                        Приложить объяснения очевидца
                                    </span>
                              </span>
                            </label>
                        </div>
                    </div>
                    <div class="field">
                        <div class="file is-info has-name">
                            <label class="file-label">
                                <input class="file-input" type="file">
                                <span class="file-cta">
                                    <span class="file-icon">
                                        <i class="fas fa-upload"></i>
                                    </span>
                                    <span class="file-label">
                                        Приложить план пожара
                                    </span>
                                 </span>
                            </label>
                        </div>
                    </div>

                </div>
            </div>
            <div class="panel"
                 style="padding: 30px 10px 20px; margin-top:20px;border-top: 1px solid #dbdbdb; background-color: #f7f7f7">
                <div class="level">
                    <p class="level-left">
                        <button id="nexttab" class="button is-primary is-outlined"><i class="fas fa-arrow-right"></i>&nbsp;
                            Следующий раздел
                        </button>
                    </p>
                    <p class="level-right">
                        <button type="submit" class="button is-success"><i class="fas fa-check"></i>&nbsp; Сохранить
                        </button>
                    </p>
                </div>
            </div>
        </form>
    </section>
{% endblock content %}
