{% extends "layout/html" %}
{% block content %}
    <div class=""><h4 class="title" style="padding: 3px 15px">Карточка 101</h4></div>
    <div class="columns is-gapless">
        <div class="column">
            <div class="tabs">
                <ul class="">
                    <li class="is-active"><a href="">Открытые</a></li>
                    <li><a href="">Закрытые</a></li>
                    <li><a href="">Все карточки</a></li>
                </ul>
            </div>
        </div>
        <div class="column is-narrow">
            <div style="border-bottom: 1px solid #dbdbdb">
                <a href="/card/add101/" class="button is-success is-outlined" style="margin: 2px 10px 2px"><i class="fas fa-plus"></i>&nbsp;Новая карточка</a>
            </div>
        </div>
    </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>№ КУИ</th>
                <th>Адрес</th>
                <th>Район</th>
                <th class="has-text-right">Дата и время</th>
                <th>&nbsp;</th>
            </tr>
            </thead>
            {% for ticket in tickets %}
                <tr>
                    <td class="has-text-right">{{ ticket.id }}</td>
                    <td>{{ ticket.location }}</td>
                    <td>{{ ticket.city_area.name|default('-') }} {% if ticket.crossroad_1_id %}({{ ticket.crossroad_1.name|default('-') }} &times; {{ ticket.crossroad_2.name|default('-') }}){% endif %}</td>
                    <td class="has-text-right">{{ ticket.created_at|date('H:i d.m.Y') }}</td>
                    <td class="has-text-right"><a href="{{ url('/card/add101/' ~ ticket.id) }}" class="button is-small is-outlined is-primary"><i class="fas fa-pencil-alt"></i>&nbsp; Редактировать</a></td>
                </tr>
            {% else %}
                <tr>
                    <td class="is-centered"><h1 class="title">Нет выбранных заявок</h1></td>
                </tr>
            {% endfor %}
        </table>
    </div>
{% endblock content %}