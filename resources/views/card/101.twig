{% extends "layout/html" %}
{% block content %}
    <div class="section container" id="vue1">
        <h4 class="title">Карточка 101</h4>
        <div class="columns is-gapless">
            <div class="column">
                <div class="tabs buttab">
                    <ul class="">
                        <li class="is-active"><a href="">Открытые</a></li>
                        <li><a href="">Закрытые</a></li>
                        <li><a href="">Все карточки</a></li>
                    </ul>
                </div>
            </div>
            <div class="column">
                <div class="tabs buttab">
                    <ul class="">
                        <li class="{% if card_type == 'real' %}is-active{% endif %}"><a href="/card/101">Боевые</a></li>
                        <li class="{% if card_type == 'other' %}is-active{% endif %}"><a href="/card101-other-rides">Прочие</a></li>
                        <li class="{% if card_type == 'drill' %}is-active{% endif %}"><a href="/card101-drill-rides">Учебные</a></li>
                        <li class="{% if card_type == 'norms-psp' %}is-active{% endif %}"><a href="/norms-psp">Нормативы по ПСП</a></li>
                    </ul>
                </div>
            </div>
            <div class="column is-narrow">
                <div>
                    <a href="/card/add101/0/{{ type }}" class="button is-basic is-main" style="margin: 2px 10px 2px"><i class="fas fa-plus"></i>&nbsp;Новая карточка</a>
                    <a href="/card/101/{{ type }}" class="button is-info is-main" style="margin: 2px 10px 2px"><i class="fas fa-crosshairs"></i>&nbsp;Сбросить фильтр</a>
                </div>
            </div>
        </div>
        <div>
            <form action="" method="get">

            </form>
            <div id="vue">
                <form action="">
                    <div class="field   has-addons">
                        <div class="control is-expanded">
                            <input type="search" class="input" name="search" value="{{ search }}" id="search-input">
                        </div>
                        <div class="control">
                        </div>

                        <div class="control">
                            <button class="button is-primary is-outlined" type="submit"><span><i class="fa fa-search"></i><span class="hidden-sm-down">&nbsp; Искать</span></span></button>
                        </div>

                    </div>
                    <div class="field is-grouped">

                        <v-datepicker-search
                                name="date_from"
                                date-string="{{ date_from }}"
                                :include-hidden="true"
                                label="С"
                        ></v-datepicker-search>
                        <v-datepicker-search
                                name="date_to"
                                date-string="{{ date_to }}"
                                :include-hidden="true"
                                label="По"
                        ></v-datepicker-search>

                    </div>

                    <div class="control">
                        <p>Район</p>
                        <select name="city_area" class="select control">
                            <option value=""></option>
                            {% for f in city_areas %}
                                <option {% if city_area is defined and city_area == f.id %} selected {% endif %} value="{{ f.id }}">{{ f.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <br>
                    <div class="control">
                        <button class="button is-primary is-outlined" type="submit"><span><i class="fa fa-search"></i><span class="hidden-sm-down">&nbsp; Искать</span></span></button>
                    </div>

                </form>
            </div>
        </div>
        <div class="panel">
            <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small" id="card101_index_table">
                <thead>
                <tr>
                    <th>№</th>
                    <th>
                        <a href="?sort=location">Адрес</a>
                    </th>
                    <th>
                        <a href="?sort=city_area_id">Район</a>
                        <form>

                        </form>
                    </th>
                    <th class="has-text-right">
                        <a href="?sort=created_at">Дата и время</a>
                    </th>
                    <th>Тип ЧС</th>
                    <th>&nbsp;</th>
                </tr>
                </thead>
                {% for ticket in tickets %}
                    <tr>
                        <td class="has-text-right">{{ ticket.kui ?? ticket.id }}</td>
                        <td>{{ ticket.location ?? ticket.fireplace }}</td>
                        <td>{{ ticket.city_area.name|default('-') }} {% if ticket.crossroad_1_id %}({{ ticket.crossroad_1.name|default('-') }} &times; {{ ticket.crossroad_2.name|default('-') }}){% endif %}</td>
                        <td class="has-text-right">{{ ticket.custom_created_at|date('H:i d.m.Y') }}</td>
                        <td class="has-text-right">{{ ticket.emergency_type ? ticket.emergency_type.name : '' }}</td>
                        <td class="has-text-right">
                            <a href="/card/add101/{{ ticket.id }}/{{ type }}" class="button is-basic is-small"><i class="fas fa-pencil-alt"></i>&nbsp; Редактировать</a>
                            {#{% if ticket.trip_result.emergency_code|default('') == 115 or ticket.trip_result.emergency_code|default('') == 116 %}
                                <a href="/reports/isk/{{ ticket.id }}/export" class="button is-info is-small"><i class="fas fa-file-word"></i>&nbsp; doc</a>
                            {% endif %}#}

                            <delete-card-btn :can-delete="{{ can_delete|json_encode() }}" :ticket-id="{{ ticket.id }}"></delete-card-btn>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td class="is-centered"><h1 class="title">Нет выбранных заявок</h1></td>
                    </tr>
                {% endfor %}
            </table>
            {% include "_templates/pagination" with {'items': tickets, 'per_page': per_page, 'other': {'date_from':date_from, 'date_to': date_to, 'search': search}} %}
        </div>
    </div>
{% endblock content %}
