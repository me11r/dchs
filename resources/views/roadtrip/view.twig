{% extends "layout/html" %}
{% block content %}
    <script src="https://api-maps.yandex.ru/2.1/?lang=ru-RU" type="text/javascript"></script>
    <script>
        window.roadTripViewData = {
            fromString: 'Алматы {{ trip.ticket.location }}',
            emergencyString: 'Алматы {{ trip.department.address }}'
        };
        ymaps.ready(function () {
            window.ymaps = ymaps;
            window.initRoadTripViewMap();
        });
    </script>
    <h4 class="title">Путевой лист {{ trip.id }} от {{ trip.created_at|date('d.m.Y H:i') }} для {{ trip.department.name }}</h4>
    <table class="table is-narrow">
        {% if not trip.is_accepted %}
            <tr>
                <td class="has-text-right is-bold">Принять в работу</td>
                <td>
                    <form method="post" action="{{ url('/roadtrip/accept/' ~ trip.id) }}">{{ csrf_field() }}<button type="submit" class="button is-warning"><i class="far fa-bell"></i>&nbsp;Принять</button></form></td>
            </tr>
        {% endif %}
        {% if trip.result is defined and trip.result.out_time is null and trip.is_accepted %}
            <tr>
                <td class="has-text-right is-bold">Выезд сил</td>
                <td>
                    <form method="post" action="{{ url('/roadtrip/force-out/' ~ trip.id) }}">{{ csrf_field() }}<button type="submit" class="button is-info"><i class="far fa-bell"></i>&nbsp;Назначить</button></form></td>
            </tr>
        {% endif %}
        <tr>
            <td class="has-text-right is-bold">Место пожара (адрес)</td>
            <td>{{ trip.ticket.location|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Наименование объекта</td>
            <td>{{ trip.ticket.object_name|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Телефон заявителя</td>
            <td>{{ trip.ticket.caller_phone|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Подразделения</td>
            <td>{{ trip.ticket['ph_' ~ trip.department_id ~'_ot']|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Пересечение улиц</td>
            <td>{% if trip.ticket.crossroad_1_id %}({{ trip.ticket.crossroad_1.name|default('-') }} &times; {{ trip.ticket.crossroad_2.name|default('-') }}){% else %}--{% endif %}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Ранг пожара
            </td>
            <td>{{ trip.ticket.fire_level.name|default('?') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Объект горения</td>
            <td>{{ trip.ticket.fire_object.name|default('?') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">
                Этажность</td>
            <td>{{ trip.ticket.storey_count|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">На каком этаже горит
            </td>
            <td>{{ trip.ticket.floor|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Конструктивные особенности</td>
            <td>{{ trip.ticket.building_description|default('') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Наличие угрозы людям</td>
            <td>{% if trip.ticket.people_in_danger ==1 %} <span class="has-text-danger is-bold">Да</span> {% else %} <span class="is-warning is-bold">Нет</span>{% endif %}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">ФИО заявителя</td>
            <td>{{ trip.ticket.caller_name|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Телефон заявителя</td>
            <td>{{ trip.ticket.caller_phone|default('-') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Время получения сообщения о ЧС</td>
            <td>{{ trip.ticket.created_at|date('d.m.Y H:i') }}</td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Время возвращение в ПЧ</td>
            <td>
                {% if trip.is_closed %}{{ trip.return_time|date('d.m.Y h:i') }}{% else %}
                    <form action="{{ url('/roadtrip/save/' ~ trip.id) }}" method="post">{{ csrf_field() }}
                        <button type="submit" class="button is-success is-outlined"><i class="fas fa-retweet"></i>&nbsp; Отметить возвращение</button>
                    </form>
                {% endif %}
            </td>
        </tr>
        <tr>
            <td class="has-text-right is-bold">Дата(день,месяц,год)</td>
            <td>{{ trip.created_at|date('d.m.Y') }}</td>
        </tr>
    </table>

    <div id="road-trip-view-yandex-map-block"></div>
{% endblock content %}
