{% extends "layout/html" %}
{% block content %}
    <div class="container">
        <div class="">
            <h4 class="title"
                style="padding: 3px 15px">{{ t('/information.kaz_mudflow') }} {{ dateHuman }}{#ГУ "Казселезащита" за #}
            </h4>
        </div>

        <div class="panel">
            <div class="level">
                <div class="level-left">
                    <a href="/mudflow-protection" class="button is-info">{{ t('back') }}</a>{#Назад#}
                </div>
                <div class="level-right">
                    <a href="/mudflowProtection/export/xls/{{ date }}" class="button is-success">{{ t('docx') }}</a>{#Сохранить в DOCX#}
                </div>
            </div>
            <div class="section">
                <p>{{ block.text_footer ?? null }}</p>
            </div>
            <div class="section" style="overflow-x: scroll">
                <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
                    <thead>
                    <tr>
                        <th>№</th>
                        <th>{{ t('information') }}</th>{#Информация#}
                        <th>{{ t('/mudflow-protection.hydro_name') }}</th>{#Наименование гидропостов и их отметка#}
                        <th>{{ t('/mudflow-protection.water_flow_rate') }}</th>{#Расход воды#}
                        <th>{{ t('/mudflow-protection.critical_water_flow_rate') }}</th>{#Критический расход воды#}
                        <th>{{ t('/mudflow-protection.turbidity_of_water') }}</th>{#Мутность воды#}
                        <th>{{ t('/mudflow-protection.max_turbidity_of_water') }}</th>{#Максимальная мутность воды#}
                        <th>{{ t('/mudflow-protection.air_temperature') }}</th>{#Температура воздуха#}
                        <th>{{ t('/mudflow-protection.water_temperature') }}</th>{#Температура воды#}
                        <th>{{ t('/mudflow-protection.precipitation') }}</th>{#Осадки#}
                        <th>{{ t('/mudflow-protection.height_of_snow') }}</th>{#Высота снега#}
                        <th>{{ t('/mudflow-protection.weather') }}</th>{#Погода#}
                        <th>{{ t('comment') }}</th>{#Комментарий#}
                        <th class="has-text-right">{{ t('datetime') }}</th>{#Дата и время#}
                    </tr>
                    </thead>
                    {% set index = 1 %}
                    {% for river in rivers %}
                        <tr>
                            <td colspan="15" style="text-align: center"><b>{{ river.name }}</b></td>
                        </tr>
                        {% for gaugingStation in river.gaugingStations %}
                            {% for record in records if record.gauging_station_id == gaugingStation.id %}

                                <tr>
                                    <td class="has-text-right">{{ index }}</td>
                                    <td>{{ record.information|default('') }}</td>
                                    <td>{{ gaugingStation.name }}</td>
                                    <td>{{ record.water_flow_rate|default('') }}</td>
                                    <td>{{ record.critical_water_flow_rate|default('') }}</td>
                                    <td>{{ record.turbidity_of_water|default('') }}</td>
                                    <td>{{ record.max_turbidity_of_water|default('') }}</td>
                                    <td>{{ record.air_temperature|default('') }}</td>
                                    <td>{{ record.water_temperature|default('') }}</td>
                                    <td>{{ record.precipitation|default('') }}</td>
                                    <td>{{ record.height_of_snow |default('')}}</td>
                                    <td>{{ record.weather|default('') }}</td>
                                    <td>{{ record.comment|default('') }}</td>
                                    <td class="has-text-right">{{ records[gaugingStation.id].updated_at|default('') }}</td>
                                </tr>

                                {% set index = index + 1 %}
                            {% endfor %}
                        {% endfor %}
                    {% endfor %}
                </table>

            </div>
            <div class="section">
                <p>{{ block.text_footer ?? null }}</p>
            </div>
        </div>
    </div>

{% endblock content %}