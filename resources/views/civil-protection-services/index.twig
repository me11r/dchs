{% extends "layout/html" %}
{% block content %}
    <div class="section container">
    <div class="">
        <h4 class="title"
            style="padding: 3px 15px">Службы гражданской защиты
        </h4>
    </div>
    <div class="columns is-gapless">
        <div style="width: 100%; border-bottom: 1px solid #dbdbdb;">
        </div>
        <div class="column is-narrow">
            <div style="border-bottom: 1px solid #dbdbdb">
                <a href="/civil-protection-services/create" class="button is-basic is-main" style="margin: 2px 10px 2px"><i class="fas fa-plus"></i>&nbsp;Создать запись</a>
            </div>
        </div>
    </div>
    <div class="panel">
        <table class="table is-narrow is-hoverable is-fullwidth is-striped is-small">
            <thead>
            <tr>
                <th>№</th>
                <th>Дата</th>
                <th>&nbsp;</th>
            </tr>
            </thead>
            <tbody>
                {% for record in records %}
                    <tr>
                        <td class="has-text-right">{{ loop.index + 1}}</td>
                        <td>
                            <p>{{ record.date|date('d.m.Y') }}</p>
                        </td>
                        <td class="has-text-right">
                            <form method="POST"
                                  onsubmit="return confirm('Вы действительно хотите удалить эту запись?');"
                                  action="{{ url(route('civil-protection-services.delete', {'id': record.id })) }}">
                                <input name="_method" type="hidden" value="DELETE">
                                {{ csrf_field() }}

                                <a href="/civil-protection-services/{{ record.id }}/edit" class="button is-small {{ record.is_active ? 'is-basic' : 'is-warning' }}">
                                    <i class="fas fa-edit"></i>&nbsp;{{ record.is_active ? 'Изменить' : 'Просмотр' }}
                                </a>

                                <a href="/civil-protection-services/export/{{ record.id }}" class="button is-small is-basic">
                                    <i class="fas fa-file-word"></i>&nbsp;Скачать
                                </a>

                                {% if user.hasRight('CAN_DELETE_CIVIL_PROTECTION_SERVICES') %}
                                    <button type="submit"
                                            class="button is-small is-danger">
                                        <i class="fas fa-trash"></i>&nbsp;Удалить
                                    </button>
                                {% endif %}

                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        {% include "_templates/pagination" with {'items': records, 'per_page': per_page } %}
    </div>
    </div>
{% endblock content %}
